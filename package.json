{
  "name": "creatyss",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint .",
    "lint:db": "eslint db --ext .ts",
    "lint:db:fix": "eslint db --ext .ts --fix",
    "lint:fix": "eslint . --fix",
    "lint:watch": "chokidar \"**/*.{ts,tsx,js,mjs}\" --ignore \"node_modules/**\" --ignore \".next/**\" -c \"pnpm run lint\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:db": "tsc --noEmit -p tsconfig.db.json",
    "typecheck:import-woocommerce": "tsc --noEmit -p tsconfig.import-woocommerce.json",
    "typecheck:watch": "tsc --noEmit --watch -p tsconfig.json --preserveWatchOutput",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --pass-with-no-tests",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push --accept-data-loss",
    "prisma:db:reset": "prisma db push --force-reset --accept-data-loss",
    "prisma:studio": "prisma studio --port 5555 --browser none",
    "bootstrap:store-admin": "tsx scripts/bootstrap-store-and-admin.ts",
    "import:woo": "tsx scripts/import-woocommerce/index.ts",
    "import:woo:reset": "tsx scripts/import-woocommerce/index.ts --reset",
    "import:woo:reset:skip-images": "tsx scripts/import-woocommerce/index.ts --reset --skip-images"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.577.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "recharts": "2.15.4",
    "shadcn": "^4.0.5",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "msw",
      "prisma",
      "sharp"
    ]
  }
}
