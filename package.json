{
  "name": "creatyss",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:watch": "chokidar \"**/*.{ts,tsx,js,mjs}\" --ignore \"node_modules/**\" --ignore \".next/**\" -c \"pnpm run lint\"",
    "typecheck": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "typecheck:import-woocommerce": "tsc --noEmit -p tsconfig.import-woocommerce.json",
    "typecheck:watch": "node --max-old-space-size=8192 ./node_modules/typescript/bin/tsc --noEmit --watch -p tsconfig.json --preserveWatchOutput",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test --pass-with-no-tests",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --accept-data-loss",
    "db:push-reset": "prisma db push --force-reset --accept-data-loss",
    "db:seed": "tsx ./prisma/seed.ts",
    "db:studio": "prisma studio --port 5555 --browser none",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push --accept-data-loss",
    "prisma:db:reset": "prisma db push --force-reset --accept-data-loss",
    "prisma:studio": "prisma studio --port 5555 --browser none",
    "bootstrap:store-admin": "tsx scripts/bootstrap-store-and-admin.ts",
    "seed:dev": "pnpm run bootstrap:store-admin && pnpm run import:woo:reset:skip-images",
    "seed:variables": "pnpm run bootstrap:store-admin && tsx scripts/seed-categories.ts && tsx scripts/seed-variable-products.ts",
    "seed:test-order": "tsx scripts/seed-test-order.ts",
    "seed:test-checkout": "tsx scripts/seed-test-checkout.ts",
    "import:woo": "tsx scripts/import-woocommerce/index.ts",
    "import:woo:reset": "tsx scripts/import-woocommerce/index.ts --reset",
    "import:woo:reset:skip-images": "tsx scripts/import-woocommerce/index.ts --reset --skip-images",
    "import:woo:sync": "tsx scripts/import-woocommerce/index.ts --no-reset",
    "import:woo:sync:skip-images": "tsx scripts/import-woocommerce/index.ts --no-reset --skip-images",
    "import:woo:normalize-product-types": "tsx scripts/import-woocommerce/normalize/normalize-imported-product-types.ts",
    "media:repair-legacy-storage-keys": "tsx scripts/repair-legacy-product-media-storage-keys.ts",
    "media:repair-legacy-storage-keys:apply": "tsx scripts/repair-legacy-product-media-storage-keys.ts --apply",
    "diagnostics:import": "tsx scripts/import-woocommerce/diagnostics/catalog-diagnostics.ts",
    "catalog:backfill-price-snapshots": "tsx scripts/backfill-product-catalog-price-snapshots.ts",
    "localization:enable-multilingual": "tsx scripts/enable-localization-multilingual.ts --apply",
    "localization:revert-multilingual": "tsx scripts/enable-localization-multilingual.ts --revert",
    "automations:run-jobs": "tsx scripts/run-automation-jobs.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@next/env": "^16.2.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "@tiptap/extension-color": "^3.21.0",
    "@tiptap/extension-highlight": "^3.21.0",
    "@tiptap/extension-link": "^3.21.0",
    "@tiptap/extension-text-align": "^3.21.0",
    "@tiptap/extension-text-style": "^3.21.0",
    "@tiptap/extension-underline": "^3.21.0",
    "@tiptap/react": "^3.21.0",
    "@tiptap/starter-kit": "^3.21.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "next": "^16.0.0",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "pg": "^8.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "recharts": "2.15.4",
    "server-only": "^0.0.1",
    "shadcn": "^4.0.5",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "msw",
      "prisma",
      "sharp"
    ]
  }
}
