{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["dom", "dom.iterable", "es2024"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./*"],
      "@db/*": ["./db/*"],
      "@db-repositories/*": ["./db/repositories/*"],
      "@db-blog": ["./db/repositories/blog/index.ts"],
      "@db-products/*": ["./db/repositories/products/*"],
      "@db-products": ["./db/repositories/products/index.ts"],
      "@db-blog/*": ["./db/repositories/blog/*"],
      "@db-cart": ["./db/repositories/cart/index.ts"],
      "@db-cart/*": ["./db/repositories/cart/*"],
      "@db-categories": ["./db/repositories/categories/index.ts"],
      "@db-categories/*": ["./db/repositories/categories/*"],
      "@db-email": ["./db/repositories/email/index.ts"],
      "@db-email/*": ["./db/repositories/email/*"],
      "@db-users": ["./db/repositories/users/index.ts"],
      "@db-users/*": ["./db/repositories/users/*"],
      "@db-roles": ["./db/repositories/roles/index.ts"],
      "@db-roles/*": ["./db/repositories/roles/*"],
      "@db-newsletter": ["./db/repositories/newsletter/index.ts"],
      "@db-newsletter/*": ["./db/repositories/newsletter/*"],
      "@db-template-system": ["./db/repositories/template-system/index.ts"],
      "@db-template-system/*": ["./db/repositories/template-system/*"],
      "@db-payments": ["./db/repositories/payments/index.ts"],
      "@db-payments/*": ["./db/repositories/payments/*"],
      "@db-media": ["./db/repositories/media/index.ts"],
      "@db-media/*": ["./db/repositories/media/*"],
      "@db-orders": ["./db/repositories/orders/index.ts"],
      "@db-orders/*": ["./db/repositories/orders/*"],
      "@db-pages": ["./db/repositories/pages/index.ts"],
      "@db-pages/*": ["./db/repositories/pages/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
