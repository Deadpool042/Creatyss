{
  "compilerOptions": {
    "target": "es2024",
    "lib": ["dom", "dom.iterable", "es2024"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./*"],
      "@db/*": ["./db/*"],
      "@db-repositories/*": ["./db/repositories/*"],
      "@db-products/*": ["./db/repositories/products/*"],
      "@db-blog/*": ["./db/repositories/blog/*"],
      "@db-cart/*": ["./db/repositories/cart/*"],
      "@db-email/*": ["./db/repositories/email/*"],
      "@db-users/*": ["./db/repositories/users/*"],
      "@db-payments/*": ["./db/repositories/payments/*"],
      "@db-media/*": ["./db/repositories/media/*"],
      "@db-orders/*": ["./db/repositories/orders/*"],
      "@db-pages/*": ["./db/repositories/pages/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
