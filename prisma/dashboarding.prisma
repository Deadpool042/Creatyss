// -----------------------------------------------------------------------------
// Domaine: dashboarding
// Responsabilité: tableaux de bord configurables, widgets, métriques pilotage.
// -----------------------------------------------------------------------------
// prisma/dashboarding.prisma

enum DashboardKind {
  PLATFORM
  STORE
  CUSTOM
}

enum DashboardStatus {
  ACTIVE
  ARCHIVED
}

enum DashboardWidgetKind {
  METRIC
  CHART
  TABLE
  STATUS
  TEXT
}

model Dashboard {
  id      String  @id @default(cuid())
  storeId String?

  kind   DashboardKind   @default(STORE)
  name   String
  slug   String
  status DashboardStatus @default(ACTIVE)

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store   Store?            @relation(fields: [storeId], references: [id], onDelete: SetNull)
  widgets DashboardWidget[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([kind])
  @@index([status])
  @@map("dashboards")
}

model DashboardWidget {
  id          String @id @default(cuid())
  dashboardId String

  kind      DashboardWidgetKind
  name      String
  sortOrder Int                 @default(0)

  config Json?

  colSpan Int @default(1)
  rowSpan Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@index([kind])
  @@map("dashboard_widgets")
}
