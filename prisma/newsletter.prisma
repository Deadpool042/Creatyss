// -----------------------------------------------------------------------------
// Domaine: newsletter
// Responsabilité: listes, abonnements, campagnes newsletter.
// -----------------------------------------------------------------------------
// prisma/newsletter.prisma

enum NewsletterSubscriptionStatus {
  PENDING
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
}

enum NewsletterCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

model NewsletterList {
  id      String @id @default(cuid())
  storeId String

  name        String
  description String?
  isDefault   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store         Store                    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  subscriptions NewsletterSubscription[]
  campaigns     NewsletterCampaign[]

  @@unique([storeId, name])
  @@index([storeId])
  @@map("newsletter_lists")
}

model NewsletterSubscription {
  id         String  @id @default(cuid())
  listId     String
  customerId String?

  email     String
  firstName String?
  lastName  String?

  status NewsletterSubscriptionStatus @default(PENDING)

  confirmedAt    DateTime?
  unsubscribedAt DateTime?
  bouncedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  list     NewsletterList @relation(fields: [listId], references: [id], onDelete: Cascade)
  customer Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([listId, email])
  @@index([listId])
  @@index([customerId])
  @@index([status])
  @@map("newsletter_subscriptions")
}

model NewsletterCampaign {
  id     String @id @default(cuid())
  listId String

  name        String
  subject     String
  previewText String?

  status NewsletterCampaignStatus @default(DRAFT)

  scheduledAt DateTime?
  sentAt      DateTime?
  cancelledAt DateTime?

  recipientsCount Int @default(0)
  opensCount      Int @default(0)
  clicksCount     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  list NewsletterList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@index([status])
  @@index([scheduledAt])
  @@map("newsletter_campaigns")
}
