/// Feature: commerce.fulfillment
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, commerce.orders

enum FulfillmentStatus {
  PENDING
  READY
  PARTIALLY_FULFILLED
  FULFILLED
  CANCELLED
  ARCHIVED
}

enum FulfillmentItemStatus {
  PENDING
  FULFILLED
  CANCELLED
  ARCHIVED
}

model Fulfillment {
  id         String  @id @default(cuid())
  storeId    String
  orderId    String
  shipmentId String?

  status FulfillmentStatus @default(PENDING)

  fulfilledAt DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  order    Order     @relation(fields: [orderId], references: [id], onDelete: Restrict)
  shipment Shipment? @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  items FulfillmentItem[]

  @@index([storeId, status])
  @@index([orderId, status])
  @@index([shipmentId])
  @@index([fulfilledAt])
  @@map("fulfillments")
}

model FulfillmentItem {
  id            String @id @default(cuid())
  fulfillmentId String
  orderLineId   String

  status   FulfillmentItemStatus @default(PENDING)
  quantity Int

  fulfilledAt DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fulfillment Fulfillment @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderLine   OrderLine   @relation(fields: [orderLineId], references: [id], onDelete: Cascade)

  @@unique([fulfillmentId, orderLineId])
  @@index([orderLineId])
  @@index([status, fulfilledAt])
  @@map("fulfillment_items")
}
