/// Feature: commerce.discounts
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, catalog.products, catalog.pricing, commerce.orders

enum DiscountStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
}

enum DiscountScopeType {
  ORDER
  PRODUCT
  PRODUCT_VARIANT
  CATEGORY
}

enum DiscountCodeStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  ARCHIVED
}

model Discount {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  status    DiscountStatus    @default(DRAFT)
  type      DiscountType
  scopeType DiscountScopeType @default(ORDER)

  percentageValue  Decimal?      @db.Decimal(5, 2)
  fixedAmountValue Decimal?      @db.Decimal(12, 2)
  currencyCode     CurrencyCode?

  startsAt DateTime?
  endsAt   DateTime?

  isAutomatic Boolean @default(false)
  priority    Int     @default(0)

  maxRedemptions        Int?
  maxRedemptionsPerCode Int?
  maxRedemptionsPerUser Int?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  codes           DiscountCode[]
  productTargets  DiscountProductTarget[]
  variantTargets  DiscountVariantTarget[]
  categoryTargets DiscountCategoryTarget[]
  redemptions     DiscountRedemption[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([storeId, isAutomatic])
  @@index([type, status])
  @@index([startsAt, endsAt])
  @@map("discounts")
}

model DiscountCode {
  id         String @id @default(cuid())
  discountId String

  code   String
  status DiscountCodeStatus @default(ACTIVE)

  maxRedemptions Int?
  redeemedCount  Int  @default(0)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  discount            Discount             @relation(fields: [discountId], references: [id], onDelete: Cascade)
  discountRedemptions DiscountRedemption[]

  @@unique([discountId, code])
  @@index([status, startsAt, endsAt])
  @@map("discount_codes")
}

model DiscountRedemption {
  id             String  @id @default(cuid())
  discountId     String
  discountCodeId String?
  orderId        String?
  customerId     String?

  redeemedAt    DateTime      @default(now())
  amountApplied Decimal?      @db.Decimal(12, 2)
  currencyCode  CurrencyCode?

  discount     Discount      @relation(fields: [discountId], references: [id], onDelete: Cascade)
  discountCode DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  order        Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([discountId, redeemedAt])
  @@index([discountCodeId])
  @@index([orderId])
  @@index([customerId, redeemedAt])
  @@map("discount_redemptions")
}

model DiscountProductTarget {
  id         String @id @default(cuid())
  discountId String
  productId  String

  createdAt DateTime @default(now())

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([discountId, productId])
  @@index([productId])
  @@map("discount_product_targets")
}

model DiscountVariantTarget {
  id         String @id @default(cuid())
  discountId String
  variantId  String

  createdAt DateTime @default(now())

  discount Discount       @relation(fields: [discountId], references: [id], onDelete: Cascade)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([discountId, variantId])
  @@index([variantId])
  @@map("discount_variant_targets")
}

model DiscountCategoryTarget {
  id         String @id @default(cuid())
  discountId String
  categoryId String

  createdAt DateTime @default(now())

  discount Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([discountId, categoryId])
  @@index([categoryId])
  @@map("discount_category_targets")
}
