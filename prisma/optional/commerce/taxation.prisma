/// Feature: commerce.taxation
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, catalog.products, catalog.pricing, commerce.orders

enum TaxRuleStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum TaxRuleScopeType {
  STORE
  CATEGORY
  PRODUCT
  PRODUCT_VARIANT
}

model TaxRule {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  status    TaxRuleStatus    @default(DRAFT)
  scopeType TaxRuleScopeType @default(STORE)

  countryCode String
  regionCode  String?

  ratePercent       Decimal @db.Decimal(7, 4)
  isIncludedInPrice Boolean @default(false)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  productTargets  TaxRuleProductTarget[]
  variantTargets  TaxRuleVariantTarget[]
  categoryTargets TaxRuleCategoryTarget[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([countryCode, regionCode, status])
  @@index([scopeType, status])
  @@index([startsAt, endsAt])
  @@map("tax_rules")
}

model TaxRuleProductTarget {
  id        String @id @default(cuid())
  taxRuleId String
  productId String

  createdAt DateTime @default(now())

  taxRule TaxRule @relation(fields: [taxRuleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([taxRuleId, productId])
  @@index([productId])
  @@map("tax_rule_product_targets")
}

model TaxRuleVariantTarget {
  id        String @id @default(cuid())
  taxRuleId String
  variantId String

  createdAt DateTime @default(now())

  taxRule TaxRule        @relation(fields: [taxRuleId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([taxRuleId, variantId])
  @@index([variantId])
  @@map("tax_rule_variant_targets")
}

model TaxRuleCategoryTarget {
  id         String @id @default(cuid())
  taxRuleId  String
  categoryId String

  createdAt DateTime @default(now())

  taxRule  TaxRule  @relation(fields: [taxRuleId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([taxRuleId, categoryId])
  @@index([categoryId])
  @@map("tax_rule_category_targets")
}
