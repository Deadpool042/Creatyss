/// Feature: commerce.gift-cards
/// Category: optional
/// Level: L3
/// DependsOn: foundation.store, commerce.orders, commerce.payments

enum GiftCardStatus {
  DRAFT
  ACTIVE
  REDEEMED
  EXPIRED
  CANCELLED
  ARCHIVED
}

enum GiftCardTransactionType {
  ISSUE
  REDEEM
  REFUND
  ADJUSTMENT
  EXPIRATION
  CANCELLATION
}

model GiftCard {
  id         String  @id @default(cuid())
  storeId    String
  customerId String?

  code   String
  status GiftCardStatus @default(DRAFT)

  initialAmount Decimal      @db.Decimal(12, 2)
  balanceAmount Decimal      @db.Decimal(12, 2)
  currencyCode  CurrencyCode

  purchasedOrderId String?
  expiresAt        DateTime?
  activatedAt      DateTime?
  redeemedAt       DateTime?
  cancelledAt      DateTime?
  archivedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store          Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer       Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  purchasedOrder Order?    @relation("GiftCardPurchasedOrder", fields: [purchasedOrderId], references: [id], onDelete: SetNull)

  transactions GiftCardTransaction[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([customerId])
  @@index([purchasedOrderId])
  @@index([expiresAt])
  @@map("gift_cards")
}

model GiftCardTransaction {
  id         String  @id @default(cuid())
  giftCardId String
  orderId    String?

  amount       Decimal      @db.Decimal(12, 2)
  currencyCode CurrencyCode

  transactionType GiftCardTransactionType
  reasonCode      String?
  notes           String?

  createdAt DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  order    Order?   @relation("GiftCardTransactionOrder", fields: [orderId], references: [id], onDelete: SetNull)

  @@index([giftCardId, createdAt])
  @@index([orderId])
  @@map("gift_card_transactions")
}
