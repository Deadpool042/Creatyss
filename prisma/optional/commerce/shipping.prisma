/// Feature: commerce.shipping
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, commerce.orders, commerce.fulfillment

enum ShippingMethodStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ShippingZoneStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ShipmentStatus {
  PENDING
  READY
  SHIPPED
  DELIVERED
  RETURNED
  CANCELLED
}

model ShippingZone {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  status    ShippingZoneStatus @default(ACTIVE)
  sortOrder Int                @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store   Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  methods ShippingMethod[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([sortOrder])
  @@map("shipping_zones")
}

model ShippingMethod {
  id             String  @id @default(cuid())
  storeId        String
  shippingZoneId String?

  code        String
  name        String
  description String?

  status ShippingMethodStatus @default(DRAFT)

  currencyCode CurrencyCode
  amount       Decimal      @db.Decimal(12, 2)

  minSubtotalAmount Decimal? @db.Decimal(12, 2)
  maxSubtotalAmount Decimal? @db.Decimal(12, 2)

  isDefault Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shippingZone ShippingZone? @relation(fields: [shippingZoneId], references: [id], onDelete: SetNull)

  checkoutSelections CheckoutShippingSelection[]
  orderSelections    OrderShippingSelection[]
  shipments          Shipment[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([shippingZoneId])
  @@index([isDefault])
  @@index([sortOrder])
  @@map("shipping_methods")
}

model Shipment {
  id               String  @id @default(cuid())
  storeId          String
  orderId          String
  shippingMethodId String?

  status ShipmentStatus @default(PENDING)

  carrier        String?
  trackingNumber String?
  trackingUrl    String?

  shippedAt   DateTime?
  deliveredAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  shippingMethod ShippingMethod? @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)
  fulfillments   Fulfillment[]

  @@index([storeId, status])
  @@index([orderId])
  @@index([shippingMethodId])
  @@index([trackingNumber])
  @@map("shipments")
}
