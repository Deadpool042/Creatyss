/// Feature: commerce.documents
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, commerce.orders

enum DocumentStatus {
  DRAFT
  GENERATED
  ISSUED
  SENT
  CANCELLED
  ARCHIVED
}

enum DocumentTypeCode {
  ORDER_CONFIRMATION
  INVOICE
  CREDIT_NOTE
  DELIVERY_NOTE
  RECEIPT
  OTHER
}

model Document {
  id      String  @id @default(cuid())
  storeId String
  orderId String?

  typeCode DocumentTypeCode
  status   DocumentStatus   @default(DRAFT)

  documentNumber String?
  title          String?

  currencyCode CurrencyCode?

  /// Contenu légal figé à l'émission (snapshot EN 16931 : vendeur, acheteur,
  /// lignes, ventilation TVA, totaux). Immuable une fois ISSUED.
  snapshot Json?

  /// Document corrigé (avoir → facture d'origine).
  parentDocumentId String?

  issuedAt    DateTime?
  sentAt      DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  fileName   String?
  mimeType   String?
  storageKey String?
  publicUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store  Store     @relation(fields: [storeId], references: [id], onDelete: Restrict)
  order  Order?    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  parent Document? @relation("DocumentCorrections", fields: [parentDocumentId], references: [id], onDelete: Restrict)

  corrections Document[]        @relation("DocumentCorrections")
  versions    DocumentVersion[]

  @@unique([storeId, documentNumber])
  @@index([storeId, typeCode, status])
  @@index([orderId])
  @@index([parentDocumentId])
  @@index([issuedAt])
  @@map("documents")
}

/// Compteur de numérotation séquentielle sans trou (par store, type, année).
/// Incrémenté sous SELECT FOR UPDATE dans la transaction d'émission.
model DocumentCounter {
  id       String          @id @default(cuid())
  storeId  String
  typeCode DocumentTypeCode
  year     Int

  lastValue Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, typeCode, year])
  @@map("document_counters")
}

model DocumentVersion {
  id         String @id @default(cuid())
  documentId String

  versionNumber Int
  status        DocumentStatus @default(DRAFT)

  fileName   String?
  mimeType   String?
  storageKey String?
  publicUrl  String?

  generatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNumber])
  @@index([documentId, status])
  @@map("document_versions")
}
