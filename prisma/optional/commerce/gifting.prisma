/// Feature: commerce.gifting
/// Category: optional
/// Level: L3
/// DependsOn: foundation.store, commerce.cart, commerce.orders, commerce.gift-cards

enum GiftRequestStatus {
  DRAFT
  SCHEDULED
  SENT
  CLAIMED
  CANCELLED
  EXPIRED
  ARCHIVED
}

model GiftRequest {
  id         String  @id @default(cuid())
  storeId    String
  orderId    String?
  customerId String?

  status GiftRequestStatus @default(DRAFT)

  senderName     String?
  senderEmail    String?
  recipientName  String?
  recipientEmail String?

  message         String?
  scheduledSendAt DateTime?
  sentAt          DateTime?
  claimedAt       DateTime?
  cancelledAt     DateTime?
  expiresAt       DateTime?
  archivedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order    Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  items GiftRequestItem[]

  @@index([storeId, status])
  @@index([orderId])
  @@index([customerId])
  @@index([scheduledSendAt, status])
  @@index([recipientEmail])
  @@map("gift_requests")
}

model GiftRequestItem {
  id            String  @id @default(cuid())
  giftRequestId String
  productId     String?
  variantId     String?

  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  giftRequest GiftRequest     @relation(fields: [giftRequestId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([giftRequestId])
  @@index([productId])
  @@index([variantId])
  @@map("gift_request_items")
}
