/// Feature: commerce.payments
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, commerce.orders, commerce.customers

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
  CANCELLED
  EXPIRED
}

enum PaymentAttemptStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

enum PaymentMethodType {
  CARD
  BANK_TRANSFER
  WALLET
  CASH_ON_DELIVERY
  OTHER
}

model Payment {
  id      String @id @default(cuid())
  storeId String
  orderId String

  status     PaymentStatus     @default(PENDING)
  methodType PaymentMethodType

  currencyCode     CurrencyCode
  amountAuthorized Decimal?     @db.Decimal(12, 2)
  amountCaptured   Decimal?     @db.Decimal(12, 2)
  amountRefunded   Decimal      @default(0) @db.Decimal(12, 2)

  provider          String?
  providerReference String?
  providerPaymentId String?

  authorizedAt DateTime?
  capturedAt   DateTime?
  failedAt     DateTime?
  cancelledAt  DateTime?
  expiredAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)
  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  attempts PaymentAttempt[]
  refunds  PaymentRefund[]

  @@index([storeId, status])
  @@index([orderId])
  @@index([provider, providerReference])
  @@index([providerPaymentId])
  @@map("payments")
}

model PaymentAttempt {
  id        String @id @default(cuid())
  paymentId String

  status PaymentAttemptStatus @default(PENDING)

  provider          String?
  providerReference String?
  idempotencyKey    String?

  requestedAmount Decimal @db.Decimal(12, 2)
  responseCode    String?
  responseMessage String?

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId, status])
  @@index([provider, providerReference])
  @@index([idempotencyKey])
  @@map("payment_attempts")
}

model PaymentRefund {
  id        String @id @default(cuid())
  paymentId String

  amount       Decimal      @db.Decimal(12, 2)
  currencyCode CurrencyCode

  provider          String?
  providerReference String?

  reasonCode String?
  notes      String?

  refundedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([provider, providerReference])
  @@map("payment_refunds")
}
