enum AttributionModelStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model AttributionModel {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  status AttributionModelStatus @default(ACTIVE)

  modelType String

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  credits AttributionCredit[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([modelType, status])
  @@map("attribution_models")
}

model AttributionCredit {
  id                 String @id @default(cuid())
  attributionModelId String

  subjectType String
  subjectId   String

  sourceCode   String
  channelCode  String?
  campaignCode String?

  creditValue Decimal @db.Decimal(8, 4)

  attributedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  attributionModel AttributionModel @relation(fields: [attributionModelId], references: [id], onDelete: Cascade)

  @@index([attributionModelId])
  @@index([subjectType, subjectId])
  @@index([sourceCode, channelCode, campaignCode])
  @@index([attributedAt])
  @@map("attribution_credits")
}
