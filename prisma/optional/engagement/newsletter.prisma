/// Feature: engagement.newsletter
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, commerce.customers, platform.email

enum NewsletterSubscriberStatus {
  PENDING
  SUBSCRIBED
  UNSUBSCRIBED
  BOUNCED
  ARCHIVED
}

enum NewsletterCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
  CANCELLED
  ARCHIVED
}

model NewsletterSubscriber {
  id      String  @id @default(cuid())
  storeId String?

  email     String
  firstName String?
  lastName  String?

  customerId String?
  status     NewsletterSubscriberStatus @default(PENDING)

  source         String?
  subscribedAt   DateTime?
  unsubscribedAt DateTime?
  bouncedAt      DateTime?
  archivedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  campaignRecipients NewsletterCampaignRecipient[]

  @@unique([storeId, email])
  @@index([storeId, status])
  @@index([customerId, status])
  @@index([subscribedAt])
  @@map("newsletter_subscribers")
}

model NewsletterCampaign {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  subjectLine String
  previewText String?

  bodyText String?
  bodyHtml String?

  status NewsletterCampaignStatus @default(DRAFT)

  scheduledAt      DateTime?
  sendingStartedAt DateTime?
  sentAt           DateTime?
  failedAt         DateTime?
  cancelledAt      DateTime?
  archivedAt       DateTime?

  provider          String?
  providerReference String?
  errorCode         String?
  errorMessage      String?

  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store     Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("NewsletterCampaignCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  recipients NewsletterCampaignRecipient[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([createdByUserId])
  @@index([scheduledAt, status])
  @@index([provider, providerReference])
  @@map("newsletter_campaigns")
}

model NewsletterCampaignRecipient {
  id                     String @id @default(cuid())
  newsletterCampaignId   String
  newsletterSubscriberId String

  email     String
  sentAt    DateTime?
  openedAt  DateTime?
  clickedAt DateTime?
  failedAt  DateTime?

  errorCode    String?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  newsletterCampaign   NewsletterCampaign   @relation(fields: [newsletterCampaignId], references: [id], onDelete: Cascade)
  newsletterSubscriber NewsletterSubscriber @relation(fields: [newsletterSubscriberId], references: [id], onDelete: Cascade)

  @@unique([newsletterCampaignId, newsletterSubscriberId])
  @@index([newsletterSubscriberId])
  @@index([sentAt])
  @@map("newsletter_campaign_recipients")
}
