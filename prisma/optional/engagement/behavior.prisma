/// Feature: engagement.behavior
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, engagement.analytics

enum BehaviorSegmentStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum BehaviorProfileStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model BehaviorSegment {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  status BehaviorSegmentStatus @default(ACTIVE)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  profileLinks BehaviorProfileSegment[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@map("behavior_segments")
}

model BehaviorProfile {
  id      String  @id @default(cuid())
  storeId String?

  subjectType String
  subjectId   String

  status BehaviorProfileStatus @default(ACTIVE)

  journeyState  String?
  interestLevel String?
  frictionLevel String?

  computedAt DateTime?
  expiresAt  DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  segmentLinks BehaviorProfileSegment[]

  @@unique([subjectType, subjectId])
  @@index([storeId, status])
  @@index([subjectType, subjectId])
  @@index([computedAt])
  @@map("behavior_profiles")
}

model BehaviorProfileSegment {
  id                String @id @default(cuid())
  behaviorProfileId String
  behaviorSegmentId String

  assignedAt DateTime @default(now())
  score      Decimal? @db.Decimal(8, 4)

  behaviorProfile BehaviorProfile @relation(fields: [behaviorProfileId], references: [id], onDelete: Cascade)
  behaviorSegment BehaviorSegment @relation(fields: [behaviorSegmentId], references: [id], onDelete: Cascade)

  @@unique([behaviorProfileId, behaviorSegmentId])
  @@index([behaviorSegmentId])
  @@map("behavior_profile_segments")
}
