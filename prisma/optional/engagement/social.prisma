enum SocialPublicationStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
  ARCHIVED
}

model SocialPublication {
  id      String  @id @default(cuid())
  storeId String?

  subjectType String?
  subjectId   String?

  channelCode String
  status      SocialPublicationStatus @default(DRAFT)

  title String?
  body  String?

  scheduledAt DateTime?
  publishedAt DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  provider          String?
  providerReference String?
  errorCode         String?
  errorMessage      String?

  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store     Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("SocialPublicationCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  assets SocialPublicationAsset[]

  @@index([storeId, status])
  @@index([subjectType, subjectId])
  @@index([channelCode, status])
  @@index([scheduledAt, status])
  @@index([createdByUserId])
  @@index([provider, providerReference])
  @@map("social_publications")
}

model SocialPublicationAsset {
  id                  String @id @default(cuid())
  socialPublicationId String
  mediaAssetId        String

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  socialPublication SocialPublication @relation(fields: [socialPublicationId], references: [id], onDelete: Cascade)
  mediaAsset        MediaAsset        @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([socialPublicationId, mediaAssetId])
  @@index([socialPublicationId, sortOrder])
  @@index([mediaAssetId])
  @@map("social_publication_assets")
}
