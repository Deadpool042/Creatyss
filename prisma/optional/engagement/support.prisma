/// Feature: engagement.support
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, commerce.customers, commerce.orders

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  RESOLVED
  CLOSED
  CANCELLED
  ARCHIVED
}

enum SupportMessageAuthorType {
  USER
  CUSTOMER
  SYSTEM
}

model SupportTicket {
  id         String  @id @default(cuid())
  storeId    String?
  customerId String?
  orderId    String?

  ticketNumber String
  subject      String
  status       SupportTicketStatus @default(OPEN)

  reasonCode String?
  notes      String?

  assignedToUserId String?

  openedAt    DateTime?
  resolvedAt  DateTime?
  closedAt    DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store      Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order      Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  assignedTo User?     @relation("SupportTicketAssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  messages SupportMessage[]

  @@unique([storeId, ticketNumber])
  @@index([storeId, status])
  @@index([customerId, status])
  @@index([orderId])
  @@index([assignedToUserId, status])
  @@map("support_tickets")
}

model SupportMessage {
  id              String @id @default(cuid())
  supportTicketId String

  authorType       SupportMessageAuthorType
  authorUserId     String?
  authorCustomerId String?

  body       String
  isInternal Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supportTicket  SupportTicket @relation(fields: [supportTicketId], references: [id], onDelete: Cascade)
  authorUser     User?         @relation("SupportMessageAuthorUser", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorCustomer Customer?     @relation("SupportMessageAuthorCustomer", fields: [authorCustomerId], references: [id], onDelete: SetNull)

  @@index([supportTicketId, createdAt])
  @@index([authorUserId])
  @@index([authorCustomerId])
  @@map("support_messages")
}
