/// Feature: engagement.recommendations
/// Category: optional
/// Level: L3
/// DependsOn: foundation.store, catalog.products, engagement.behavior, engagement.conversion

enum RecommendationRuleStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RecommendationTargetType {
  PRODUCT
  PRODUCT_VARIANT
  CATEGORY
}

model RecommendationRule {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  targetType RecommendationTargetType @default(PRODUCT)
  status     RecommendationRuleStatus @default(DRAFT)

  isActive Boolean @default(true)
  priority Int     @default(0)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  links RecommendationLink[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([isActive, priority])
  @@map("recommendation_rules")
}

model RecommendationLink {
  id                   String @id @default(cuid())
  recommendationRuleId String

  sourceType RecommendationTargetType
  sourceId   String

  targetType RecommendationTargetType
  targetId   String

  score     Decimal? @db.Decimal(8, 4)
  sortOrder Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recommendationRule RecommendationRule @relation(fields: [recommendationRuleId], references: [id], onDelete: Cascade)

  @@unique([recommendationRuleId, sourceType, sourceId, targetType, targetId])
  @@index([sourceType, sourceId, sortOrder])
  @@index([targetType, targetId])
  @@map("recommendation_links")
}
