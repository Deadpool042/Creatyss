/// Feature: platform.notifications
/// Category: optional
/// Level: L1
/// DependsOn: foundation.store, platform.email

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
  CANCELLED
  ARCHIVED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  REALTIME
}

enum NotificationRecipientType {
  USER
  CUSTOMER
}

model Notification {
  id      String  @id @default(cuid())
  storeId String?

  recipientType       NotificationRecipientType
  recipientUserId     String?
  recipientCustomerId String?

  channel NotificationChannel
  status  NotificationStatus  @default(PENDING)

  subjectType String?
  subjectId   String?

  title String?
  body  String

  readAt      DateTime?
  sentAt      DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  errorCode    String?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store             Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  recipientUser     User?     @relation("NotificationRecipientUser", fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientCustomer Customer? @relation("NotificationRecipientCustomer", fields: [recipientCustomerId], references: [id], onDelete: SetNull)

  @@index([storeId, status])
  @@index([recipientType, status])
  @@index([recipientUserId, status])
  @@index([recipientCustomerId, status])
  @@index([channel, status])
  @@index([subjectType, subjectId])
  @@map("notifications")
}

model NotificationPreference {
  id      String  @id @default(cuid())
  storeId String?

  recipientKey        String
  recipientType       NotificationRecipientType
  recipientUserId     String?
  recipientCustomerId String?

  channel NotificationChannel
  topic   String

  isEnabled Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store             Store?    @relation(fields: [storeId], references: [id], onDelete: SetNull)
  recipientUser     User?     @relation("NotificationPreferenceUser", fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientCustomer Customer? @relation("NotificationPreferenceCustomer", fields: [recipientCustomerId], references: [id], onDelete: SetNull)

  @@unique([recipientKey, channel, topic])
  @@index([storeId])
  @@index([recipientUserId, channel])
  @@index([recipientCustomerId, channel])
  @@index([topic, channel])
  @@map("notification_preferences")
}
