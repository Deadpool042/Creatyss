/// Feature: platform.import
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, cross-cutting.jobs

enum ImportRequestStatus {
  REQUESTED
  VALIDATED
  REJECTED
  RUNNING
  PARTIALLY_APPLIED
  APPLIED
  FAILED
  CANCELLED
  EXPIRED
  ARCHIVED
}

model ImportDefinition {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  targetType String
  formatCode String

  isActive         Boolean @default(true)
  requiresApproval Boolean @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  requests ImportRequest[]

  @@unique([storeId, code])
  @@index([storeId, isActive])
  @@index([targetType, formatCode])
  @@map("import_definitions")
}

model ImportRequest {
  id                 String  @id @default(cuid())
  storeId            String?
  importDefinitionId String

  requestedByUserId String?

  status ImportRequestStatus @default(REQUESTED)

  scopeType String?
  scopeId   String?

  sourceFileName   String?
  sourceMimeType   String?
  sourceStorageKey String?
  sourcePublicUrl  String?

  mappingJson    String?
  validationJson String?
  resultJson     String?

  errorCode    String?
  errorMessage String?

  requestedAt DateTime?
  validatedAt DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?
  cancelledAt DateTime?
  expiresAt   DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store            Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  importDefinition ImportDefinition @relation(fields: [importDefinitionId], references: [id], onDelete: Restrict)
  requestedBy      User?            @relation("ImportRequestRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  artifacts ImportArtifact[]

  @@index([storeId, status])
  @@index([importDefinitionId, status])
  @@index([requestedByUserId])
  @@index([scopeType, scopeId])
  @@index([expiresAt])
  @@map("import_requests")
}

model ImportArtifact {
  id              String @id @default(cuid())
  importRequestId String

  code String
  kind String

  fileName   String?
  mimeType   String?
  storageKey String?
  publicUrl  String?

  payloadJson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  importRequest ImportRequest @relation(fields: [importRequestId], references: [id], onDelete: Cascade)

  @@unique([importRequestId, code])
  @@index([importRequestId, kind])
  @@map("import_artifacts")
}
