/// Feature: platform.workflow
/// Category: optional
/// Level: L3
/// DependsOn: foundation.store, platform.scheduling, cross-cutting.jobs

enum WorkflowDefinitionStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum WorkflowInstanceStatus {
  PENDING
  RUNNING
  BLOCKED
  COMPLETED
  FAILED
  CANCELLED
  ARCHIVED
}

enum WorkflowStepStatus {
  PENDING
  READY
  RUNNING
  BLOCKED
  COMPLETED
  FAILED
  SKIPPED
  CANCELLED
}

model WorkflowDefinition {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  subjectType String
  status      WorkflowDefinitionStatus @default(DRAFT)

  version   Int     @default(1)
  isDefault Boolean @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  instances WorkflowInstance[]
  steps     WorkflowDefinitionStep[]

  @@unique([storeId, code, version])
  @@index([storeId, status])
  @@index([subjectType, status])
  @@index([isDefault])
  @@map("workflow_definitions")
}

model WorkflowDefinitionStep {
  id                   String @id @default(cuid())
  workflowDefinitionId String

  code        String
  name        String
  description String?

  sortOrder  Int     @default(0)
  isRequired Boolean @default(true)
  isTerminal Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflowDefinition WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)

  stepInstances WorkflowStepInstance[]

  @@unique([workflowDefinitionId, code])
  @@index([workflowDefinitionId, sortOrder])
  @@map("workflow_definition_steps")
}

model WorkflowInstance {
  id                   String  @id @default(cuid())
  storeId              String?
  workflowDefinitionId String

  subjectType String
  subjectId   String

  status WorkflowInstanceStatus @default(PENDING)

  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  createdByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store              Store?             @relation(fields: [storeId], references: [id], onDelete: SetNull)
  workflowDefinition WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Restrict)
  createdBy          User?              @relation("WorkflowInstanceCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  stepInstances WorkflowStepInstance[]

  @@index([storeId, status])
  @@index([workflowDefinitionId, status])
  @@index([subjectType, subjectId])
  @@index([createdByUserId])
  @@map("workflow_instances")
}

model WorkflowStepInstance {
  id                       String @id @default(cuid())
  workflowInstanceId       String
  workflowDefinitionStepId String

  status WorkflowStepStatus @default(PENDING)

  startedAt   DateTime?
  completedAt DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?

  reasonCode String?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflowInstance       WorkflowInstance       @relation(fields: [workflowInstanceId], references: [id], onDelete: Cascade)
  workflowDefinitionStep WorkflowDefinitionStep @relation(fields: [workflowDefinitionStepId], references: [id], onDelete: Restrict)

  @@unique([workflowInstanceId, workflowDefinitionStepId])
  @@index([workflowInstanceId, status])
  @@index([workflowDefinitionStepId, status])
  @@map("workflow_step_instances")
}
