/// Feature: platform.integrations
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, platform.webhooks

enum IntegrationStatus {
  DRAFT
  ACTIVE
  INACTIVE
  FAILED
  ARCHIVED
}

enum IntegrationType {
  PAYMENT_PROVIDER
  SHIPPING_PROVIDER
  EMAIL_PROVIDER
  SOCIAL_PROVIDER
  ERP
  CRM
  MARKETPLACE
  STORAGE
  OTHER
}

enum IntegrationCredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum IntegrationSyncStatus {
  IDLE
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model Integration {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  type     IntegrationType
  provider String
  status   IntegrationStatus @default(DRAFT)

  isEnabled Boolean @default(false)
  isSandbox Boolean @default(true)

  baseUrl        String?
  webhookBaseUrl String?

  lastCheckedAt DateTime?
  activatedAt   DateTime?
  failedAt      DateTime?
  archivedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  credentials      IntegrationCredential[]
  syncStates       IntegrationSyncState[]
  webhookEndpoints WebhookEndpoint[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([type, provider])
  @@index([isEnabled, isSandbox])
  @@map("integrations")
}

model IntegrationCredential {
  id            String @id @default(cuid())
  integrationId String

  key          String
  secretHash   String?
  secretPrefix String?
  valueHint    String?

  /// Charge chiffree reversible (AES-256-GCM) permettant a un adaptateur de
  /// rappeler l'API du fournisseur avec le secret en clair. Payload opaque
  /// encodant iv + authTag + ciphertext ; la cle de chiffrement vit hors DB
  /// (variable d'environnement), jamais en base. Absent pour les credentials
  /// verification-only (secretHash suffit).
  encryptedValue String?

  /// Version de la cle/algorithme de chiffrement ayant produit encryptedValue,
  /// pour permettre une rotation de cle sans migration de donnees bloquante.
  encryptionVersion Int?

  status IntegrationCredentialStatus @default(ACTIVE)

  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, key])
  @@index([integrationId, status])
  @@index([expiresAt])
  @@map("integration_credentials")
}

model IntegrationSyncState {
  id            String @id @default(cuid())
  integrationId String

  scopeType String
  scopeId   String?

  status IntegrationSyncStatus @default(IDLE)

  lastJobId     String?
  lastRunAt     DateTime?
  lastSuccessAt DateTime?
  lastFailureAt DateTime?

  cursor            String?
  externalReference String?
  errorCode         String?
  errorMessage      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, scopeType, scopeId])
  @@index([integrationId, status])
  @@index([scopeType, scopeId])
  @@index([lastJobId])
  @@map("integration_sync_states")
}
