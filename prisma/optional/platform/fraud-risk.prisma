/// Feature: platform.fraud-risk
/// Category: optional
/// Level: L3
/// DependsOn: foundation.store, commerce.orders, commerce.payments

enum FraudRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FraudRiskDecisionType {
  ALLOW
  REVIEW
  BLOCK
  CONDITIONAL_ALLOW
}

enum FraudRiskReviewStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
  ARCHIVED
}

model FraudRiskAssessment {
  id      String  @id @default(cuid())
  storeId String?

  subjectType String
  subjectId   String

  level FraudRiskLevel
  score Decimal?       @db.Decimal(8, 2)

  decisionType FraudRiskDecisionType
  reasonCode   String?
  notes        String?

  assessedAt DateTime?
  expiresAt  DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  decisions FraudRiskDecision[]
  reviews   FraudRiskReview[]

  @@index([storeId, level])
  @@index([subjectType, subjectId])
  @@index([decisionType, level])
  @@index([expiresAt])
  @@map("fraud_risk_assessments")
}

model FraudRiskDecision {
  id                    String  @id @default(cuid())
  fraudRiskAssessmentId String
  decidedByUserId       String?

  type       FraudRiskDecisionType
  reasonCode String?
  notes      String?

  createdAt DateTime @default(now())

  fraudRiskAssessment FraudRiskAssessment @relation(fields: [fraudRiskAssessmentId], references: [id], onDelete: Cascade)
  decidedBy           User?               @relation("FraudRiskDecisionDecidedByUser", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([fraudRiskAssessmentId, createdAt])
  @@index([decidedByUserId])
  @@index([type, createdAt])
  @@map("fraud_risk_decisions")
}

model FraudRiskReview {
  id                    String  @id @default(cuid())
  fraudRiskAssessmentId String
  assignedToUserId      String?

  status     FraudRiskReviewStatus @default(OPEN)
  reasonCode String?
  notes      String?

  openedAt    DateTime?
  resolvedAt  DateTime?
  cancelledAt DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  fraudRiskAssessment FraudRiskAssessment @relation(fields: [fraudRiskAssessmentId], references: [id], onDelete: Cascade)
  assignedTo          User?               @relation("FraudRiskReviewAssignedToUser", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([fraudRiskAssessmentId, status])
  @@index([assignedToUserId, status])
  @@index([openedAt, resolvedAt])
  @@map("fraud_risk_reviews")
}
