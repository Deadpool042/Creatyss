/// Feature: platform.consent
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, commerce.customers

enum ConsentStatus {
  GRANTED
  DENIED
  REVOKED
  EXPIRED
}

enum ConsentSubjectType {
  CUSTOMER
  USER
  VISITOR
}

model ConsentPurpose {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  isRequired Boolean @default(false)
  isActive   Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  records ConsentRecord[]

  @@unique([storeId, code])
  @@index([storeId, isActive])
  @@index([isRequired, isActive])
  @@map("consent_purposes")
}

model ConsentRecord {
  id      String  @id @default(cuid())
  storeId String?

  subjectType ConsentSubjectType
  subjectId   String

  purposeId String
  status    ConsentStatus

  source     String?
  legalBasis String?

  grantedAt DateTime?
  deniedAt  DateTime?
  revokedAt DateTime?
  expiresAt DateTime?

  evidenceRef String?
  ipAddress   String?
  userAgent   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store   Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  purpose ConsentPurpose @relation(fields: [purposeId], references: [id], onDelete: Cascade)

  @@unique([subjectType, subjectId, purposeId])
  @@index([storeId, status])
  @@index([subjectType, subjectId])
  @@index([purposeId, status])
  @@index([expiresAt])
  @@map("consent_records")
}
