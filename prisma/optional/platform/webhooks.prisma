/// Feature: platform.webhooks
/// Category: optional
/// Level: L2
/// DependsOn: foundation.store, cross-cutting.jobs

enum WebhookEndpointStatus {
  DRAFT
  ACTIVE
  INACTIVE
  FAILED
  ARCHIVED
}

enum WebhookDeliveryStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
}

model WebhookEndpoint {
  id            String  @id @default(cuid())
  storeId       String?
  integrationId String?

  code        String
  name        String
  description String?

  status WebhookEndpointStatus @default(DRAFT)

  targetUrl    String
  secretHash   String?
  secretPrefix String?

  isEnabled Boolean @default(false)

  eventType String
  version   String?

  timeoutMs   Int?
  maxAttempts Int  @default(3)

  lastTriggeredAt DateTime?
  lastSucceededAt DateTime?
  lastFailedAt    DateTime?
  archivedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store       Store?       @relation(fields: [storeId], references: [id], onDelete: SetNull)
  integration Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  deliveries WebhookDelivery[]

  @@unique([storeId, code])
  @@index([integrationId])
  @@index([storeId, status])
  @@index([eventType, status])
  @@index([isEnabled])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id                String @id @default(cuid())
  webhookEndpointId String

  status WebhookDeliveryStatus @default(PENDING)

  eventType      String
  eventId        String?
  idempotencyKey String?

  requestUrl         String
  requestMethod      String  @default("POST")
  requestHeadersJson String?
  requestBodyJson    String?

  responseStatusCode  Int?
  responseHeadersJson String?
  responseBodyText    String?

  attemptCount Int       @default(0)
  scheduledAt  DateTime?
  startedAt    DateTime?
  finishedAt   DateTime?
  expiresAt    DateTime?

  errorCode    String?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  webhookEndpoint WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id], onDelete: Cascade)

  @@index([webhookEndpointId, status])
  @@index([eventType, eventId])
  @@index([idempotencyKey])
  @@index([scheduledAt, status])
  @@index([finishedAt])
  @@map("webhook_deliveries")
}
