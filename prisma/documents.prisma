// -----------------------------------------------------------------------------
// Domaine: documents
// Responsabilité: documents commerciaux (factures, avoirs), cycle vie documentaire.
// -----------------------------------------------------------------------------
// prisma/documents.prisma

enum DocumentKind {
  INVOICE
  CREDIT_NOTE
}

enum DocumentStatus {
  DRAFT
  ISSUED
  SENT
  CANCELLED
  ARCHIVED
}

model CommercialDocument {
  id      String @id @default(cuid())
  storeId String

  kind   DocumentKind
  status DocumentStatus @default(DRAFT)

  documentNumber  String
  orderId         String?
  returnRequestId String?

  currencyCode CurrencyCode

  subtotalAmount Decimal @db.Decimal(12, 2)
  taxAmount      Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)

  issuedAt    DateTime?
  sentAt      DateTime?
  cancelledAt DateTime?

  storagePath String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  order         Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  returnRequest ReturnRequest? @relation(fields: [returnRequestId], references: [id], onDelete: SetNull)

  @@unique([storeId, documentNumber])
  @@index([storeId])
  @@index([orderId])
  @@index([returnRequestId])
  @@index([kind])
  @@index([status])
  @@map("commercial_documents")
}
