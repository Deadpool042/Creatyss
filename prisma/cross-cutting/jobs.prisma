/// Feature: cross-cutting.jobs
/// Category: cross-cutting
/// Level: L1
/// DependsOn: foundation.store

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  EXPIRED
  ARCHIVED
}

enum JobPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

model Job {
  id      String  @id @default(cuid())
  storeId String?

  typeCode String
  status   JobStatus   @default(PENDING)
  priority JobPriority @default(NORMAL)

  subjectType String?
  subjectId   String?

  idempotencyKey   String?
  deduplicationKey String?

  payloadJson  String?
  resultJson   String?
  errorCode    String?
  errorMessage String?

  scheduledAt DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?
  expiresAt   DateTime?

  maxAttempts  Int @default(1)
  attemptCount Int @default(0)

  createdByUserId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  archivedAt      DateTime?

  store     Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("JobCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  attempts JobAttempt[]

  @@unique([idempotencyKey])
  @@index([storeId, status])
  @@index([typeCode, status])
  @@index([priority, status])
  @@index([scheduledAt, status])
  @@index([subjectType, subjectId])
  @@index([createdByUserId])
  @@map("jobs")
}

model JobAttempt {
  id    String @id @default(cuid())
  jobId String

  attemptNumber Int
  status        JobStatus @default(PENDING)

  startedAt  DateTime?
  finishedAt DateTime?

  errorCode    String?
  errorMessage String?
  workerRef    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, attemptNumber])
  @@index([jobId, status])
  @@index([startedAt, finishedAt])
  @@map("job_attempts")
}
