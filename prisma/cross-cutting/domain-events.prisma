/// Feature: cross-cutting.domain-events
/// Category: cross-cutting
/// Level: L1
/// DependsOn: foundation.store

enum DomainEventStatus {
  PENDING
  PUBLISHED
  FAILED
  CANCELLED
  ARCHIVED
}

model DomainEvent {
  id      String  @id @default(cuid())
  storeId String?

  eventType    String
  eventVersion Int    @default(1)

  aggregateType String
  aggregateId   String

  status DomainEventStatus @default(PENDING)

  idempotencyKey String?
  payloadJson    String
  metadataJson   String?

  occurredAt  DateTime?
  publishedAt DateTime?
  failedAt    DateTime?
  archivedAt  DateTime?

  errorCode    String?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  deliveries DomainEventDelivery[]

  @@unique([idempotencyKey])
  @@index([storeId, status])
  @@index([eventType, status])
  @@index([aggregateType, aggregateId])
  @@index([occurredAt])
  @@map("domain_events")
}

model DomainEventDelivery {
  id            String @id @default(cuid())
  domainEventId String

  consumerCode String
  status       DomainEventStatus @default(PENDING)

  attemptCount Int @default(0)

  deliveredAt DateTime?
  failedAt    DateTime?

  errorCode    String?
  errorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  domainEvent DomainEvent @relation(fields: [domainEventId], references: [id], onDelete: Cascade)

  @@unique([domainEventId, consumerCode])
  @@index([consumerCode, status])
  @@index([deliveredAt])
  @@map("domain_event_deliveries")
}
