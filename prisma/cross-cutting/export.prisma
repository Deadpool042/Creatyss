enum ExportRequestStatus {
  REQUESTED
  RUNNING
  GENERATED
  FAILED
  CANCELLED
  EXPIRED
  ARCHIVED
}

model ExportDefinition {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  sourceType String
  formatCode String

  isActive Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  requests ExportRequest[]

  @@unique([storeId, code])
  @@index([storeId, isActive])
  @@index([sourceType, formatCode])
  @@map("export_definitions")
}

model ExportRequest {
  id                 String  @id @default(cuid())
  storeId            String?
  exportDefinitionId String

  requestedByUserId String?

  status ExportRequestStatus @default(REQUESTED)

  scopeType String?
  scopeId   String?

  filterJson String?
  resultJson String?

  errorCode    String?
  errorMessage String?

  requestedAt DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?
  cancelledAt DateTime?
  expiresAt   DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store            Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  exportDefinition ExportDefinition @relation(fields: [exportDefinitionId], references: [id], onDelete: Restrict)
  requestedBy      User?            @relation("ExportRequestRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: SetNull)

  artifacts ExportArtifact[]

  @@index([storeId, status])
  @@index([exportDefinitionId, status])
  @@index([requestedByUserId])
  @@index([scopeType, scopeId])
  @@index([expiresAt])
  @@map("export_requests")
}

model ExportArtifact {
  id              String @id @default(cuid())
  exportRequestId String

  code String
  kind String

  fileName   String?
  mimeType   String?
  storageKey String?
  publicUrl  String?
  sizeBytes  Int?

  payloadJson String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exportRequest ExportRequest @relation(fields: [exportRequestId], references: [id], onDelete: Cascade)

  @@unique([exportRequestId, code])
  @@index([exportRequestId, kind])
  @@map("export_artifacts")
}
