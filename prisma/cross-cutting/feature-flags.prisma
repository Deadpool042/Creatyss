/// Feature: cross-cutting.feature-flags
/// Category: cross-cutting
/// Level: L1
/// DependsOn: foundation.store

enum FeatureFlagStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum FeatureFlagScopeType {
  GLOBAL
  STORE
  USER
}

model FeatureFlag {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  status    FeatureFlagStatus    @default(DRAFT)
  scopeType FeatureFlagScopeType @default(GLOBAL)

  isEnabledByDefault Boolean @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  overrides FeatureFlagOverride[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([scopeType, status])
  @@map("feature_flags")
}

model FeatureFlagOverride {
  id            String @id @default(cuid())
  featureFlagId String

  scopeType FeatureFlagScopeType
  scopeId   String

  isEnabled Boolean

  startsAt DateTime?
  endsAt   DateTime?

  reasonCode String?
  notes      String?

  createdByUserId String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  featureFlag FeatureFlag @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("FeatureFlagOverrideCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([featureFlagId, scopeType, scopeId])
  @@index([scopeType, scopeId])
  @@index([startsAt, endsAt])
  @@index([createdByUserId])
  @@map("feature_flag_overrides")
}
