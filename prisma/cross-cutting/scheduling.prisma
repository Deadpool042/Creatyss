enum SchedulePlanStatus {
  DRAFT
  ACTIVE
  INACTIVE
  CANCELLED
  EXPIRED
  ARCHIVED
}

enum ScheduleSubjectType {
  MARKETING_CAMPAIGN
  NEWSLETTER_CAMPAIGN
  SOCIAL_PUBLICATION
  PUBLIC_EVENT
  PAGE
  BLOG_POST
  HOMEPAGE
  OTHER
}

model SchedulePlan {
  id      String  @id @default(cuid())
  storeId String?

  subjectType ScheduleSubjectType
  subjectId   String

  code        String?
  name        String?
  description String?

  status SchedulePlanStatus @default(DRAFT)

  timezone String    @default("Europe/Paris")
  startsAt DateTime?
  endsAt   DateTime?

  createdByUserId String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  cancelledAt DateTime?
  archivedAt  DateTime?

  store     Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdBy User?  @relation("SchedulePlanCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)

  windows     ScheduleWindow[]
  occurrences ScheduleOccurrence[]

  @@index([storeId, status])
  @@index([subjectType, subjectId])
  @@index([createdByUserId])
  @@index([startsAt, endsAt])
  @@map("schedule_plans")
}

model ScheduleWindow {
  id             String @id @default(cuid())
  schedulePlanId String

  code String?
  name String?

  startsAt DateTime
  endsAt   DateTime

  isActive Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  schedulePlan SchedulePlan @relation(fields: [schedulePlanId], references: [id], onDelete: Cascade)

  @@index([schedulePlanId, isActive])
  @@index([startsAt, endsAt])
  @@map("schedule_windows")
}

model ScheduleOccurrence {
  id             String @id @default(cuid())
  schedulePlanId String

  scheduledFor DateTime
  executedAt   DateTime?
  cancelledAt  DateTime?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedulePlan SchedulePlan @relation(fields: [schedulePlanId], references: [id], onDelete: Cascade)

  @@index([schedulePlanId, isActive])
  @@index([scheduledFor])
  @@index([executedAt])
  @@map("schedule_occurrences")
}
