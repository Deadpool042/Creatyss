/// Feature: cross-cutting.marketing
/// Category: cross-cutting
/// Level: L1
/// DependsOn: foundation.store, foundation.identity, cross-cutting.domain-events

enum MarketingIntentStatus {
  PROPOSED
  APPROVED
  REJECTED
  ARCHIVED
}

enum MarketingIntentType {
  PROMOTE_EDITORIAL_CONTENT
  PROMOTE_COMMERCE_EVENT
  PROMOTE_PRODUCT
}

enum MarketingIntentSubjectType {
  BLOG_POST
  HOMEPAGE
  EDITORIAL_PAGE
  LEGAL_PAGE
  PUBLIC_EVENT
  PRODUCT
}

enum MarketingIntentChannel {
  NEWSLETTER
  SOCIAL
}

model MarketingIntent {
  id      String  @id @default(cuid())
  storeId String?

  status     MarketingIntentStatus @default(PROPOSED)
  intentType MarketingIntentType

  subjectType MarketingIntentSubjectType
  subjectId   String

  suggestedChannels MarketingIntentChannel[] @default([])

  deduplicationKey        String
  sourceDomainEventId     String?
  lastSourceDomainEventId String?

  contextJson Json?

  reviewedAt       DateTime?
  reviewedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store                 Store?       @relation(fields: [storeId], references: [id], onDelete: SetNull)
  sourceDomainEvent     DomainEvent? @relation("MarketingIntentSourceDomainEvent", fields: [sourceDomainEventId], references: [id], onDelete: SetNull)
  lastSourceDomainEvent DomainEvent? @relation("MarketingIntentLastSourceDomainEvent", fields: [lastSourceDomainEventId], references: [id], onDelete: SetNull)
  reviewedBy            User?        @relation("MarketingIntentReviewedByUser", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@unique([deduplicationKey])
  @@index([storeId, status])
  @@index([subjectType, subjectId])
  @@index([sourceDomainEventId])
  @@index([lastSourceDomainEventId])
  @@index([reviewedByUserId])
  @@map("marketing_intents")
}
