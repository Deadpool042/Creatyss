// -----------------------------------------------------------------------------
// Domaine: orders
// Responsabilité: commande durable, lignes, snapshots, cycle métier commande.
// -----------------------------------------------------------------------------
// prisma/orders.prisma

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum OrderLineType {
  PRODUCT
  GIFT_CARD
}

model Order {
  id         String  @id @default(cuid())
  storeId    String
  customerId String?
  checkoutId String? @unique

  orderNumber String
  status      OrderStatus @default(PENDING)

  currencyCode   CurrencyCode
  subtotalAmount Decimal      @db.Decimal(12, 2)
  discountAmount Decimal      @default(0) @db.Decimal(12, 2)
  shippingAmount Decimal      @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal      @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal      @db.Decimal(12, 2)

  customerEmail     String
  customerFirstName String?
  customerLastName  String?
  customerPhone     String?

  billingFirstName   String?
  billingLastName    String?
  billingCompany     String?
  billingLine1       String?
  billingLine2       String?
  billingPostalCode  String?
  billingCity        String?
  billingRegion      String?
  billingCountryCode String?
  billingPhone       String?

  shippingFirstName   String?
  shippingLastName    String?
  shippingCompany     String?
  shippingLine1       String?
  shippingLine2       String?
  shippingPostalCode  String?
  shippingCity        String?
  shippingRegion      String?
  shippingCountryCode String?
  shippingPhone       String?

  notes       String?
  placedAt    DateTime?
  cancelledAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store                Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer             Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  checkout             Checkout?               @relation(fields: [checkoutId], references: [id], onDelete: Restrict)
  lines                OrderLine[]
  payments             Payment[]
  shippingSelection    OrderShippingSelection?
  fulfillments         Fulfillment[]
  returnRequests       ReturnRequest[]
  discounts            OrderDiscount[]
  couponRedemptions    CouponRedemption[]
  loyaltyTransactions  LoyaltyTransaction[]
  giftCardTransactions GiftCardTransaction[]
  commercialDocuments  CommercialDocument[]
  fraudRiskAssessments FraudRiskAssessment[]
  attributionRecords   AttributionRecord[]
  emailMessages        EmailMessage[]
  giftingContext       GiftingContext?
  notifications        Notification[]
  supportTickets       SupportTicket[]

  @@unique([storeId, orderNumber])
  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([placedAt])
  @@map("orders")
}

model OrderLine {
  id      String @id @default(cuid())
  orderId String

  type OrderLineType @default(PRODUCT)

  productId String?
  variantId String?

  productSlugSnapshot String?
  productNameSnapshot String
  variantNameSnapshot String?
  skuSnapshot         String?

  quantity           Int
  unitPriceAmount    Decimal @db.Decimal(12, 2)
  lineSubtotalAmount Decimal @db.Decimal(12, 2)
  lineDiscountAmount Decimal @default(0) @db.Decimal(12, 2)
  lineTaxAmount      Decimal @default(0) @db.Decimal(12, 2)
  lineTotalAmount    Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant          ProductVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)
  fulfillmentLines FulfillmentLine[]
  returnLines      ReturnLine[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_lines")
}
