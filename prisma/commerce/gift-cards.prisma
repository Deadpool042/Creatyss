// -----------------------------------------------------------------------------
// Domaine: gift-cards
// Responsabilité: cartes cadeaux, émission, solde, consommation.
// -----------------------------------------------------------------------------
// prisma/gift-cards.prisma

enum GiftCardStatus {
  DRAFT
  ACTIVE
  DISABLED
  EXPIRED
  REDEEMED
  ARCHIVED
}

enum GiftCardTransactionType {
  ISSUE
  REDEEM
  ADJUST
  EXPIRE
  INVALIDATE
}

model GiftCard {
  id         String  @id @default(cuid())
  storeId    String
  customerId String?

  code          String
  initialAmount Decimal      @db.Decimal(12, 2)
  balanceAmount Decimal      @db.Decimal(12, 2)
  currencyCode  CurrencyCode

  status GiftCardStatus @default(DRAFT)

  expiresAt   DateTime?
  activatedAt DateTime?
  disabledAt  DateTime?
  expiredAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer     Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  transactions GiftCardTransaction[]

  @@unique([storeId, code])
  @@index([storeId])
  @@index([customerId])
  @@index([status])
  @@index([expiresAt])
  @@map("gift_cards")
}

model GiftCardTransaction {
  id         String  @id @default(cuid())
  giftCardId String
  orderId    String?

  type               GiftCardTransactionType
  amount             Decimal                 @db.Decimal(12, 2)
  balanceAfterAmount Decimal                 @db.Decimal(12, 2)

  reason    String?
  createdAt DateTime @default(now())

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([giftCardId])
  @@index([orderId])
  @@index([type])
  @@map("gift_card_transactions")
}
