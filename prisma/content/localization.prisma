// -----------------------------------------------------------------------------
// Domaine: localization
// Responsabilité: locales, valeurs localisées, fallback.
// -----------------------------------------------------------------------------
// prisma/localization.prisma

enum LocalizationValueStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model LocaleDefinition {
  id      String @id @default(cuid())
  storeId String

  code         String
  languageCode String
  countryCode  String?
  label        String

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store                 Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  pageLocalizations     PageLocalization[]
  blogPostLocalizations BlogPostLocalization[]
  productLocalizations  ProductLocalization[]

  @@unique([storeId, code])
  @@unique([storeId, id])
  @@index([storeId])
  @@index([isDefault])
  @@index([isActive])
  @@map("locale_definitions")
}

model PageLocalization {
  id       String @id @default(cuid())
  storeId  String
  localeId String
  pageId   String

  title       String?
  description String?

  status LocalizationValueStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store  Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  locale LocaleDefinition @relation(fields: [storeId, localeId], references: [storeId, id], onDelete: Cascade)
  page   Page             @relation(fields: [storeId, pageId], references: [storeId, id], onDelete: Cascade)

  @@unique([pageId, localeId])
  @@index([storeId])
  @@index([localeId])
  @@index([status])
  @@map("page_localizations")
}

model BlogPostLocalization {
  id         String @id @default(cuid())
  storeId    String
  localeId   String
  blogPostId String

  title   String?
  excerpt String?
  content String?

  status LocalizationValueStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  locale   LocaleDefinition @relation(fields: [storeId, localeId], references: [storeId, id], onDelete: Cascade)
  blogPost BlogPost         @relation(fields: [storeId, blogPostId], references: [storeId, id], onDelete: Cascade)

  @@unique([blogPostId, localeId])
  @@index([storeId])
  @@index([localeId])
  @@index([status])
  @@map("blog_post_localizations")
}

model ProductLocalization {
  id        String @id @default(cuid())
  storeId   String
  localeId  String
  productId String

  name             String?
  shortDescription String?
  description      String?

  status LocalizationValueStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store   Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  locale  LocaleDefinition @relation(fields: [storeId, localeId], references: [storeId, id], onDelete: Cascade)
  product Product          @relation(fields: [storeId, productId], references: [storeId, id], onDelete: Cascade)

  @@unique([productId, localeId])
  @@index([storeId])
  @@index([localeId])
  @@index([status])
  @@map("product_localizations")
}
