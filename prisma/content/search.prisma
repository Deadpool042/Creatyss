enum SearchDocumentStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model SearchDocument {
  id      String @id @default(cuid())
  storeId String

  subjectType String
  subjectId   String

  localeCode String?
  status     SearchDocumentStatus @default(ACTIVE)

  indexedText String

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, subjectType, subjectId, localeCode])
  @@index([storeId, status])
  @@index([subjectType, subjectId])
  @@index([localeCode])
  @@index([publishedAt])
  @@map("search_documents")
}
