// -----------------------------------------------------------------------------
// Domaine: blog
// Responsabilité: articles de blog, catégories, publication.
// -----------------------------------------------------------------------------
// prisma/blog.prisma

enum BlogPostStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BlogCategoryStatus {
  ACTIVE
  ARCHIVED
}

model BlogCategory {
  id      String @id @default(cuid())
  storeId String

  slug        String
  name        String
  description String?
  status      BlogCategoryStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store     Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  postLinks BlogPostCategory[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([status])
  @@map("blog_categories")
}

model BlogPost {
  id      String @id @default(cuid())
  storeId String

  slug    String
  title   String
  excerpt String?
  content String?

  coverImageId String?
  status       BlogPostStatus @default(DRAFT)
  isFeatured   Boolean        @default(false)
  publishedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store         Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coverImage    MediaAsset?        @relation(fields: [coverImageId], references: [id], onDelete: SetNull)
  categoryLinks BlogPostCategory[]
  seo           SeoMetadata?
  localizations BlogPostLocalization[]

  @@unique([storeId, slug])
  @@unique([storeId, id])
  @@index([storeId])
  @@index([status])
  @@index([isFeatured])
  @@index([publishedAt])
  @@map("blog_posts")
}

model BlogPostCategory {
  id         String @id @default(cuid())
  postId     String
  categoryId String

  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  post     BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([postId, categoryId])
  @@index([postId])
  @@index([categoryId])
  @@index([isPrimary])
  @@map("blog_post_categories")
}
