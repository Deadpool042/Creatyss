enum ApiClientStatus {
  DRAFT
  ACTIVE
  INACTIVE
  REVOKED
  ARCHIVED
}

enum ApiClientSecretStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model ApiClient {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  status ApiClientStatus @default(DRAFT)

  clientId  String  @unique
  publicKey String?

  lastUsedAt  DateTime?
  activatedAt DateTime?
  revokedAt   DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  secrets          ApiClientSecret[]
  permissions      ApiClientPermission[]
  auditLogsAsActor AuditLog[]            @relation("AuditLogActorApiClient")

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([status, lastUsedAt])
  @@map("api_clients")
}

model ApiClientSecret {
  id          String @id @default(cuid())
  apiClientId String

  secretHash   String
  secretPrefix String?

  status ApiClientSecretStatus @default(ACTIVE)

  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiClient ApiClient @relation(fields: [apiClientId], references: [id], onDelete: Cascade)

  @@index([apiClientId, status])
  @@index([expiresAt])
  @@map("api_client_secrets")
}

model ApiClientPermission {
  id          String @id @default(cuid())
  apiClientId String

  code        String
  resource    String
  action      String
  description String?

  grantedByUserId String?
  revokedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  apiClient ApiClient @relation(fields: [apiClientId], references: [id], onDelete: Cascade)
  grantedBy User?     @relation("ApiClientPermissionGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([apiClientId, code])
  @@index([resource, action])
  @@index([grantedByUserId])
  @@map("api_client_permissions")
}
