/// Feature: foundation.store
/// Category: core
/// Level: core
/// DependsOn:

enum StoreStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum StoreDomainType {
  PRIMARY
  SECONDARY
  PREVIEW
  INTERNAL
}

enum CurrencyCode {
  EUR
  USD
  GBP
  CHF
  CAD
}

model Store {
  id     String      @id @default(cuid())
  code   String      @unique
  name   String
  slug   String      @unique
  status StoreStatus @default(DRAFT)

  legalName    String?
  supportEmail String?
  supportPhone String?

  defaultLocaleCode String
  defaultCurrency   CurrencyCode @default(EUR)
  timezone          String       @default("Europe/Paris")

  isProduction Boolean @default(false)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  activatedAt DateTime?
  archivedAt  DateTime?

  domains                 StoreDomain[]
  users                   User[]
  customers               Customer[]
  productTypes            ProductType[]
  products                Product[]
  categories              Category[]
  mediaAssets             MediaAsset[]
  priceLists              PriceList[]
  inventoryItems          InventoryItem[]
  availabilityRecords     AvailabilityRecord[]
  carts                   Cart[]
  checkouts               Checkout[]
  orders                  Order[]
  shippingZones           ShippingZone[]
  shippingMethods         ShippingMethod[]
  shipments               Shipment[]
  payments                Payment[]
  documents               Document[]
  returnRequests          ReturnRequest[]
  discounts               Discount[]
  pages                   Page[]
  blogCategories          BlogCategory[]
  blogPosts               BlogPost[]
  homepages               Homepage[]
  seoMetadata             SeoMetadata[]
  apiClients              ApiClient[]
  auditLogs               AuditLog[]
  jobs                    Job[]
  integrations            Integration[]
  webhookEndpoints        WebhookEndpoint[]
  approvalRequests        ApprovalRequest[]
  schedulePlans           SchedulePlan[]
  workflowDefinitions     WorkflowDefinition[]
  workflowInstances       WorkflowInstance[]
  consentPurposes         ConsentPurpose[]
  consentRecords          ConsentRecord[]
  importDefinitions       ImportDefinition[]
  importRequests          ImportRequest[]
  exportDefinitions       ExportDefinition[]
  exportRequests          ExportRequest[]
  featureFlags            FeatureFlag[]
  emailMessages           EmailMessage[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  fraudRiskAssessments    FraudRiskAssessment[]
  newsletterSubscribers   NewsletterSubscriber[]
  newsletterCampaigns     NewsletterCampaign[]
  publicEvents            PublicEvent[]
  supportTickets          SupportTicket[]
  crmContacts             CrmContact[]
  crmTags                 CrmTag[]
  conversionFlows         ConversionFlow[]
  socialPublications      SocialPublication[]
  analyticsMetrics        AnalyticsMetric[]
  attributionModels       AttributionModel[]
  behaviorSegments        BehaviorSegment[]
  behaviorProfiles        BehaviorProfile[]
  localizationLocales     LocalizationLocale[]
  localizedValues         LocalizedValue[]
  recommendationRules     RecommendationRule[]
  searchDocuments         SearchDocument[]
  monitoringChecks        MonitoringCheck[]
  observabilitySignals    ObservabilitySignal[]
  domainEvents            DomainEvent[]
  taxRules                TaxRule[]
  channels                Channel[]
  salesPolicies           SalesPolicy[]
  sellabilityDecisions    SellabilityDecision[]
  bundles                 Bundle[]
  giftCards               GiftCard[]
  giftRequests            GiftRequest[]
  loyaltyAccounts         LoyaltyAccount[]
  subscriptions           Subscription[]
  aiProviders             AiProvider[]
  aiTasks                 AiTask[]
  fulfillments            Fulfillment[]

  @@index([status])
  @@index([slug])
  @@map("stores")
}

model StoreDomain {
  id      String          @id @default(cuid())
  storeId String
  host    String
  type    StoreDomainType @default(SECONDARY)

  isEnabled   Boolean @default(true)
  isCanonical Boolean @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  disabledAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, host])
  @@index([storeId, type])
  @@index([host])
  @@map("store_domains")
}

