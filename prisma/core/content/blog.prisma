enum BlogPostStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum BlogCategoryStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

model BlogCategory {
  id      String @id @default(cuid())
  storeId String

  code             String
  slug             String
  name             String
  shortDescription String?
  description      String?

  status     BlogCategoryStatus @default(DRAFT)
  sortOrder  Int                @default(0)
  isFeatured Boolean            @default(false)

  primaryImageId String?
  coverImageId   String?

  publishedAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  primaryImage MediaAsset? @relation("BlogCategoryPrimaryImage", fields: [primaryImageId], references: [id], onDelete: SetNull)
  coverImage   MediaAsset? @relation("BlogCategoryCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)

  postLinks BlogPostCategory[]

  @@unique([storeId, code])
  @@unique([storeId, slug])
  @@index([storeId, status])
  @@index([storeId, isFeatured])
  @@index([sortOrder])
  @@index([primaryImageId])
  @@index([coverImageId])
  @@map("blog_categories")
}

model BlogPost {
  id      String @id @default(cuid())
  storeId String

  slug    String
  title   String
  excerpt String?
  body    String?

  status     BlogPostStatus @default(DRAFT)
  isFeatured Boolean        @default(false)

  authorName         String?
  readingTimeMinutes Int?

  primaryImageId String?
  coverImageId   String?

  publishedAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  primaryImage MediaAsset? @relation("BlogPostPrimaryImage", fields: [primaryImageId], references: [id], onDelete: SetNull)
  coverImage   MediaAsset? @relation("BlogPostCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)

  categoryLinks      BlogPostCategory[]
  homepageFeaturedIn HomepageFeaturedBlogPost[]

  @@unique([storeId, slug])
  @@index([storeId, status])
  @@index([storeId, isFeatured])
  @@index([publishedAt])
  @@index([primaryImageId])
  @@index([coverImageId])
  @@map("blog_posts")
}

model BlogPostCategory {
  id             String @id @default(cuid())
  blogPostId     String
  blogCategoryId String

  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blogPost     BlogPost     @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  blogCategory BlogCategory @relation(fields: [blogCategoryId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, blogCategoryId])
  @@index([blogCategoryId, isPrimary])
  @@index([blogCategoryId, sortOrder])
  @@index([blogPostId, isPrimary])
  @@map("blog_post_categories")
}
