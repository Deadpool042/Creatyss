/// Feature: content.pages
/// Category: core
/// Level: core
/// DependsOn: foundation.store, content.seo

enum PageStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PageBlockType {
  RICH_TEXT
  IMAGE
  IMAGE_TEXT_SPLIT
  FEATURED_PRODUCTS
  FEATURED_CATEGORIES
  CTA
  HTML
}

model Page {
  id      String @id @default(cuid())
  storeId String

  code             String
  slug             String
  title            String
  shortDescription String?
  body             String?

  status       PageStatus @default(DRAFT)
  isSystemPage Boolean    @default(false)

  primaryImageId String?
  coverImageId   String?

  publishedAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  primaryImage MediaAsset? @relation("PagePrimaryImage", fields: [primaryImageId], references: [id], onDelete: SetNull)
  coverImage   MediaAsset? @relation("PageCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)

  sections PageSection[]

  @@unique([storeId, code])
  @@unique([storeId, slug])
  @@index([storeId, status])
  @@index([primaryImageId])
  @@index([coverImageId])
  @@map("pages")
}

model PageSection {
  id     String @id @default(cuid())
  pageId String

  code     String
  title    String?
  subtitle String?
  body     String?

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  primaryImageId String?
  coverImageId   String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  page         Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  primaryImage MediaAsset? @relation("PageSectionPrimaryImage", fields: [primaryImageId], references: [id], onDelete: SetNull)
  coverImage   MediaAsset? @relation("PageSectionCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)

  blocks PageBlock[]

  @@unique([pageId, code])
  @@index([pageId, isActive])
  @@index([pageId, sortOrder])
  @@index([primaryImageId])
  @@index([coverImageId])
  @@map("page_sections")
}

model PageBlock {
  id            String @id @default(cuid())
  pageSectionId String

  code String
  type PageBlockType

  title    String?
  subtitle String?
  body     String?

  primaryImageId   String?
  secondaryImageId String?

  ctaLabel String?
  ctaHref  String?

  htmlContent String?

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  pageSection    PageSection @relation(fields: [pageSectionId], references: [id], onDelete: Cascade)
  primaryImage   MediaAsset? @relation("PageBlockPrimaryImage", fields: [primaryImageId], references: [id], onDelete: SetNull)
  secondaryImage MediaAsset? @relation("PageBlockSecondaryImage", fields: [secondaryImageId], references: [id], onDelete: SetNull)

  @@unique([pageSectionId, code])
  @@index([pageSectionId, isActive])
  @@index([pageSectionId, sortOrder])
  @@index([type])
  @@index([primaryImageId])
  @@index([secondaryImageId])
  @@map("page_blocks")
}
