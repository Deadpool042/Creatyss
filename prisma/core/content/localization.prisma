enum LocalizationLocaleStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum LocalizationValueStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

model LocalizationLocale {
  id      String  @id @default(cuid())
  storeId String?

  code         String
  languageCode String
  countryCode  String?
  name         String

  status    LocalizationLocaleStatus @default(ACTIVE)
  isDefault Boolean                  @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  values LocalizedValue[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([storeId, isDefault])
  @@map("localization_locales")
}

model LocalizedValue {
  id      String  @id @default(cuid())
  storeId String?

  subjectType String
  subjectId   String
  fieldName   String

  localeId String
  status   LocalizationValueStatus @default(DRAFT)

  valueText  String
  isFallback Boolean @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store  Store?             @relation(fields: [storeId], references: [id], onDelete: SetNull)
  locale LocalizationLocale @relation(fields: [localeId], references: [id], onDelete: Cascade)

  @@unique([subjectType, subjectId, fieldName, localeId])
  @@index([storeId, status])
  @@index([subjectType, subjectId])
  @@index([fieldName])
  @@index([localeId, status])
  @@map("localized_values")
}
