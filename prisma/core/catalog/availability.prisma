/// Feature: catalog.availability
/// Category: core
/// Level: core
/// DependsOn: foundation.store, catalog.products

enum AvailabilityStatus {
  AVAILABLE
  UNAVAILABLE
  PREORDER
  BACKORDER
  DISCONTINUED
  ARCHIVED
}

enum AvailabilityPolicyStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AvailabilityOverrideType {
  FORCE_AVAILABLE
  FORCE_UNAVAILABLE
  FORCE_PREORDER
  FORCE_BACKORDER
}

model AvailabilityRecord {
  id        String @id @default(cuid())
  storeId   String
  variantId String

  status     AvailabilityStatus @default(UNAVAILABLE)
  isSellable Boolean            @default(false)

  sellableFrom  DateTime?
  sellableUntil DateTime?

  preorderStartsAt DateTime?
  preorderEndsAt   DateTime?

  backorderAllowed Boolean @default(false)

  reasonCode String?
  notes      String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store   Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  policies  AvailabilityPolicy[]
  overrides AvailabilityOverride[]

  @@unique([storeId, variantId])
  @@index([storeId, status])
  @@index([storeId, isSellable])
  @@index([variantId, isSellable])
  @@index([status, sellableFrom, sellableUntil])
  @@index([backorderAllowed])
  @@map("availability_records")
}

model AvailabilityPolicy {
  id                   String @id @default(cuid())
  availabilityRecordId String

  code        String
  name        String
  description String?

  status AvailabilityPolicyStatus @default(ACTIVE)

  priority   Int     @default(0)
  isBlocking Boolean @default(false)
  reasonCode String?
  notes      String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  availabilityRecord AvailabilityRecord @relation(fields: [availabilityRecordId], references: [id], onDelete: Cascade)

  @@unique([availabilityRecordId, code])
  @@index([availabilityRecordId, status])
  @@index([availabilityRecordId, priority])
  @@index([status, isBlocking])
  @@map("availability_policies")
}

model AvailabilityOverride {
  id                   String @id @default(cuid())
  availabilityRecordId String

  type     AvailabilityOverrideType
  reason   String?
  notes    String?
  isActive Boolean                  @default(true)

  startsAt DateTime?
  endsAt   DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  availabilityRecord AvailabilityRecord @relation(fields: [availabilityRecordId], references: [id], onDelete: Cascade)

  @@index([availabilityRecordId, type])
  @@index([availabilityRecordId, isActive])
  @@index([startsAt, endsAt])
  @@map("availability_overrides")
}
