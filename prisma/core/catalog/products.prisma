/// Feature: catalog.products
/// Category: core
/// Level: core
/// DependsOn: foundation.store, catalog.categories, catalog.media

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProductVariantStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum RelatedProductType {
  RELATED
  CROSS_SELL
  UP_SELL
  ACCESSORY
  SIMILAR
}

model ProductType {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  slug        String
  description String?

  isActive Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict)

  products Product[]
  options  ProductOption[]

  @@unique([storeId, code])
  @@unique([storeId, slug])
  @@index([storeId, isActive])
  @@map("product_types")
}

model Product {
  id             String  @id @default(cuid())
  storeId        String
  productTypeId  String?
  primaryImageId String?

  skuRoot          String?
  slug             String
  name             String
  shortDescription String?
  description      String?

  prices        ProductPrice[]
  cartLines     CartLine[]
  checkoutLines CheckoutLine[]
  orderLines    OrderLine[]

  status ProductStatus @default(DRAFT)

  isFeatured   Boolean @default(false)
  isStandalone Boolean @default(true)

  publishedAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  productType  ProductType? @relation(fields: [productTypeId], references: [id], onDelete: SetNull)
  primaryImage MediaAsset?  @relation("ProductPrimaryImage", fields: [primaryImageId], references: [id], onDelete: SetNull)

  variants                  ProductVariant[]
  relatedFrom               RelatedProduct[]           @relation("RelatedProductFrom")
  relatedTo                 RelatedProduct[]           @relation("RelatedProductTo")
  homepageFeaturedIn        HomepageFeaturedProduct[]
  productCategories         ProductCategory[]
  conversionFlowLinks       ConversionFlowProduct[]
  channelStatuses           ChannelProductStatus[]
  giftRequestItems          GiftRequestItem[]
  bundleItems               BundleItem[]
  subscriptionItems         SubscriptionItem[]
  discountProductTargets    DiscountProductTarget[]
  taxRuleProductTargets     TaxRuleProductTarget[]
  salesPolicyProductTargets SalesPolicyProductTarget[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([productTypeId])
  @@index([primaryImageId])
  @@index([status])
  @@index([isFeatured])
  @@map("products")
}

model ProductVariant {
  id             String  @id @default(cuid())
  productId      String
  primaryImageId String?

  sku  String
  slug String?
  name String?

  prices              ProductVariantPrice[]
  cartLines           CartLine[]
  checkoutLines       CheckoutLine[]
  orderLines          OrderLine[]
  inventoryItems      InventoryItem[]
  availabilityRecords AvailabilityRecord[]

  status ProductVariantStatus @default(DRAFT)

  isDefault Boolean @default(false)
  sortOrder Int     @default(0)

  barcode           String?
  externalReference String?

  weightGrams Int?
  widthMm     Int?
  heightMm    Int?
  depthMm     Int?

  publishedAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product                   Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  primaryImage              MediaAsset?                 @relation("ProductVariantPrimaryImage", fields: [primaryImageId], references: [id], onDelete: SetNull)
  optionValues              ProductVariantOptionValue[]
  channelStatuses           ChannelVariantStatus[]
  bundleItems               BundleItem[]
  giftRequestItems          GiftRequestItem[]
  subscriptionItems         SubscriptionItem[]
  discountVariantTargets    DiscountVariantTarget[]
  taxRuleVariantTargets     TaxRuleVariantTarget[]
  salesPolicyVariantTargets SalesPolicyVariantTarget[]

  @@unique([productId, sku])
  @@unique([productId, slug])
  @@index([productId, status])
  @@index([productId, isDefault])
  @@index([primaryImageId])
  @@index([sortOrder])
  @@map("product_variants")
}

model ProductOption {
  id            String  @id @default(cuid())
  productTypeId String?

  code        String
  name        String
  description String?

  sortOrder     Int     @default(0)
  isRequired    Boolean @default(false)
  isVariantAxis Boolean @default(true)
  isActive      Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  productType ProductType? @relation(fields: [productTypeId], references: [id], onDelete: SetNull)

  values ProductOptionValue[]

  @@unique([productTypeId, code])
  @@index([productTypeId, isActive])
  @@index([sortOrder])
  @@map("product_options")
}

model ProductOptionValue {
  id       String @id @default(cuid())
  optionId String

  code      String
  value     String
  label     String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  option       ProductOption               @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variantLinks ProductVariantOptionValue[]

  @@unique([optionId, code])
  @@index([optionId, isActive])
  @@index([sortOrder])
  @@map("product_option_values")
}

model ProductVariantOptionValue {
  id            String @id @default(cuid())
  variantId     String
  optionValueId String

  createdAt DateTime @default(now())

  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@index([optionValueId])
  @@map("product_variant_option_values")
}

model RelatedProduct {
  id              String @id @default(cuid())
  sourceProductId String
  targetProductId String

  type      RelatedProductType @default(RELATED)
  sortOrder Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceProduct Product @relation("RelatedProductFrom", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct Product @relation("RelatedProductTo", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, targetProductId, type])
  @@index([targetProductId, type])
  @@index([sourceProductId, sortOrder])
  @@map("related_products")
}
