enum PriceListStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PriceTargetType {
  PRODUCT
  PRODUCT_VARIANT
}

model PriceList {
  id      String  @id @default(cuid())
  storeId String?

  code        String
  name        String
  description String?

  currencyCode CurrencyCode
  status       PriceListStatus @default(DRAFT)

  isDefault Boolean   @default(false)
  startsAt  DateTime?
  endsAt    DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  productPrices ProductPrice[]
  variantPrices ProductVariantPrice[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([storeId, isDefault])
  @@index([currencyCode, status])
  @@index([startsAt, endsAt])
  @@map("price_lists")
}

model ProductPrice {
  id          String @id @default(cuid())
  productId   String
  priceListId String

  amount          Decimal  @db.Decimal(12, 2)
  compareAtAmount Decimal? @db.Decimal(12, 2)
  costAmount      Decimal? @db.Decimal(12, 2)

  startsAt DateTime?
  endsAt   DateTime?

  isActive Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([productId, priceListId])
  @@index([priceListId, isActive])
  @@index([productId, isActive])
  @@index([startsAt, endsAt])
  @@map("product_prices")
}

model ProductVariantPrice {
  id          String @id @default(cuid())
  variantId   String
  priceListId String

  amount          Decimal  @db.Decimal(12, 2)
  compareAtAmount Decimal? @db.Decimal(12, 2)
  costAmount      Decimal? @db.Decimal(12, 2)

  startsAt DateTime?
  endsAt   DateTime?

  isActive Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  priceList PriceList      @relation(fields: [priceListId], references: [id], onDelete: Cascade)

  @@unique([variantId, priceListId])
  @@index([priceListId, isActive])
  @@index([variantId, isActive])
  @@index([startsAt, endsAt])
  @@map("product_variant_prices")
}
