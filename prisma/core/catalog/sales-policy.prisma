enum SalesPolicyStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum SellabilityStatus {
  SELLABLE
  NOT_SELLABLE
  CONDITIONAL
}

enum SalesPolicyScopeType {
  STORE
  CATEGORY
  PRODUCT
  PRODUCT_VARIANT
}

model SalesPolicy {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  status    SalesPolicyStatus    @default(DRAFT)
  scopeType SalesPolicyScopeType @default(STORE)

  countryCode      String?
  customerTypeCode String?

  startsAt DateTime?
  endsAt   DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  productTargets  SalesPolicyProductTarget[]
  variantTargets  SalesPolicyVariantTarget[]
  categoryTargets SalesPolicyCategoryTarget[]
  decisions       SellabilityDecision[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([scopeType, status])
  @@index([countryCode])
  @@index([startsAt, endsAt])
  @@map("sales_policies")
}

model SellabilityDecision {
  id            String  @id @default(cuid())
  salesPolicyId String?
  storeId       String

  subjectType SalesPolicyScopeType
  subjectId   String

  status     SellabilityStatus
  reasonCode String?
  notes      String?

  decidedAt DateTime?
  expiresAt DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  salesPolicy SalesPolicy? @relation(fields: [salesPolicyId], references: [id], onDelete: SetNull)
  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, status])
  @@index([subjectType, subjectId])
  @@index([salesPolicyId])
  @@index([expiresAt])
  @@map("sellability_decisions")
}

model SalesPolicyProductTarget {
  id            String @id @default(cuid())
  salesPolicyId String
  productId     String

  createdAt DateTime @default(now())

  salesPolicy SalesPolicy @relation(fields: [salesPolicyId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([salesPolicyId, productId])
  @@index([productId])
  @@map("sales_policy_product_targets")
}

model SalesPolicyVariantTarget {
  id            String @id @default(cuid())
  salesPolicyId String
  variantId     String

  createdAt DateTime @default(now())

  salesPolicy SalesPolicy    @relation(fields: [salesPolicyId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([salesPolicyId, variantId])
  @@index([variantId])
  @@map("sales_policy_variant_targets")
}

model SalesPolicyCategoryTarget {
  id            String @id @default(cuid())
  salesPolicyId String
  categoryId    String

  createdAt DateTime @default(now())

  salesPolicy SalesPolicy @relation(fields: [salesPolicyId], references: [id], onDelete: Cascade)
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([salesPolicyId, categoryId])
  @@index([categoryId])
  @@map("sales_policy_category_targets")
}
