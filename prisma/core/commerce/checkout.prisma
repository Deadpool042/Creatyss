/// Feature: commerce.checkout
/// Category: core
/// Level: core
/// DependsOn: foundation.store, commerce.cart, commerce.customers

enum CheckoutStatus {
  OPEN
  READY
  COMPLETED
  EXPIRED
  CANCELLED
}

enum CheckoutAddressType {
  BILLING
  SHIPPING
}

model Checkout {
  id         String  @id @default(cuid())
  storeId    String
  customerId String?
  cartId     String?

  status CheckoutStatus @default(OPEN)

  currencyCode CurrencyCode
  email        String?

  expiresAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?
  cancelledAt DateTime?
  expiredAt   DateTime?

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  cart     Cart?     @relation(fields: [cartId], references: [id], onDelete: SetNull)

  lines                 CheckoutLine[]
  addresses             CheckoutAddress[]
  shippingSelection     CheckoutShippingSelection?
  orders                Order[]
  inventoryReservations InventoryReservation[]

  @@index([storeId, status])
  @@index([customerId, status])
  @@index([cartId])
  @@index([expiresAt])
  @@map("checkouts")
}

model CheckoutLine {
  id         String @id @default(cuid())
  checkoutId String
  productId  String
  variantId  String

  quantity        Int
  unitPriceAmount Decimal  @db.Decimal(12, 2)
  compareAtAmount Decimal? @db.Decimal(12, 2)

  productName String
  variantName String?
  sku         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkout Checkout       @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  product  Product        @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant  ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([checkoutId, variantId])
  @@index([checkoutId])
  @@index([productId])
  @@index([variantId])
  @@map("checkout_lines")
}

model CheckoutAddress {
  id         String              @id @default(cuid())
  checkoutId String
  type       CheckoutAddressType

  firstName String?
  lastName  String?
  company   String?

  line1       String
  line2       String?
  postalCode  String
  city        String
  region      String?
  countryCode String

  phone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkout Checkout @relation(fields: [checkoutId], references: [id], onDelete: Cascade)

  @@unique([checkoutId, type])
  @@index([checkoutId])
  @@map("checkout_addresses")
}

model CheckoutShippingSelection {
  id               String  @id @default(cuid())
  checkoutId       String  @unique
  shippingMethodId String?

  methodCode   String
  methodName   String
  amount       Decimal      @db.Decimal(12, 2)
  currencyCode CurrencyCode

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checkout       Checkout        @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  shippingMethod ShippingMethod? @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)

  @@index([shippingMethodId])
  @@map("checkout_shipping_selections")
}
