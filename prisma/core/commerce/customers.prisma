/// Feature: commerce.customers
/// Category: core
/// Level: core
/// DependsOn: foundation.store, foundation.identity

enum CustomerStatus {
  LEAD
  ACTIVE
  INACTIVE
  BLOCKED
  ARCHIVED
}

enum CustomerAddressType {
  BILLING
  SHIPPING
  BOTH
}

enum ContactChannel {
  EMAIL
  SMS
  PHONE
}

model Customer {
  id      String  @id @default(cuid())
  storeId String

  email       String
  firstName   String?
  lastName    String?
  displayName String?
  phone       String?

  status CustomerStatus @default(LEAD)

  carts     Cart[]
  checkouts Checkout[]
  orders    Order[]

  isGuest      Boolean @default(false)
  acceptsEmail Boolean @default(false)
  acceptsSms   Boolean @default(false)
  notes        String?

  firstSeenAt DateTime?
  lastSeenAt  DateTime?
  activatedAt DateTime?
  blockedAt   DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store  @relation(fields: [storeId], references: [id], onDelete: Restrict)

  addresses                CustomerAddress[]
  contactPreferences       CustomerContactPreference[]
  returnRequests           ReturnRequest[]
  discountRedemptions      DiscountRedemption[]
  eventRegistrations       EventRegistration[]
  eventReservations        EventReservation[]
  notificationsAsRecipient Notification[]              @relation("NotificationRecipientCustomer")
  notificationPreferences  NotificationPreference[]    @relation("NotificationPreferenceCustomer")
  newsletterSubscriptions  NewsletterSubscriber[]
  supportTickets           SupportTicket[]
  supportMessagesAsAuthor  SupportMessage[]            @relation("SupportMessageAuthorCustomer")
  crmContact               CrmContact?
  giftCards                GiftCard[]
  giftRequests             GiftRequest[]
  loyaltyAccount           LoyaltyAccount?
  subscriptions            Subscription[]

  @@unique([storeId, email])
  @@index([storeId])
  @@index([status])
  @@index([isGuest])
  @@index([email])
  @@map("customers")
}

model CustomerAddress {
  id         String @id @default(cuid())
  customerId String

  type  CustomerAddressType @default(SHIPPING)
  label String?

  firstName String?
  lastName  String?
  company   String?

  line1       String
  line2       String?
  postalCode  String
  city        String
  region      String?
  countryCode String

  phone String?

  isDefault Boolean @default(false)
  isActive  Boolean @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, type])
  @@index([customerId, isDefault])
  @@index([countryCode, postalCode])
  @@map("customer_addresses")
}

model CustomerContactPreference {
  id         String @id @default(cuid())
  customerId String

  channel ContactChannel
  topic   String

  isEnabled Boolean @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  enabledAt  DateTime?
  disabledAt DateTime?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, channel, topic])
  @@index([customerId, isEnabled])
  @@index([channel, topic, isEnabled])
  @@map("customer_contact_preferences")
}
