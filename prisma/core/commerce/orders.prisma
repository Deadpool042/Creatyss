/// Feature: commerce.orders
/// Category: core
/// Level: core
/// DependsOn: foundation.store, commerce.customers, commerce.checkout, catalog.products, catalog.pricing

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum OrderAddressType {
  BILLING
  SHIPPING
}

model Order {
  id         String  @id @default(cuid())
  storeId    String
  customerId String?
  checkoutId String?
  cartId     String?

  orderNumber String
  status      OrderStatus @default(PENDING)

  currencyCode CurrencyCode

  subtotalAmount Decimal @db.Decimal(12, 2)
  shippingAmount Decimal @db.Decimal(12, 2)
  discountAmount Decimal @db.Decimal(12, 2)
  taxAmount      Decimal @db.Decimal(12, 2)
  totalAmount    Decimal @db.Decimal(12, 2)

  customerEmail     String?
  customerFirstName String?
  customerLastName  String?

  notes String?

  placedAt    DateTime?
  cancelledAt DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  checkout Checkout? @relation(fields: [checkoutId], references: [id], onDelete: SetNull)
  cart     Cart?     @relation(fields: [cartId], references: [id], onDelete: SetNull)

  purchasedGiftCards    GiftCard[]              @relation("GiftCardPurchasedOrder")
  giftCardTransactions  GiftCardTransaction[]   @relation("GiftCardTransactionOrder")
  lines                 OrderLine[]
  addresses             OrderAddress[]
  shippingSelection     OrderShippingSelection?
  statusHistory         OrderStatusHistory[]
  shipments             Shipment[]
  payments              Payment[]
  documents             Document[]
  returnRequests        ReturnRequest[]
  discountRedemptions   DiscountRedemption[]
  supportTickets        SupportTicket[]
  giftRequests          GiftRequest[]
  loyaltyTransactions   LoyaltyTransaction[]
  fulfillments          Fulfillment[]
  inventoryReservations InventoryReservation[]

  @@unique([storeId, orderNumber])
  @@index([storeId, status])
  @@index([customerId, status])
  @@index([checkoutId])
  @@index([cartId])
  @@index([placedAt])
  @@map("orders")
}

model OrderLine {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  variantId String?

  quantity           Int
  unitPriceAmount    Decimal  @db.Decimal(12, 2)
  compareAtAmount    Decimal? @db.Decimal(12, 2)
  lineSubtotalAmount Decimal  @db.Decimal(12, 2)
  lineDiscountAmount Decimal  @db.Decimal(12, 2)
  lineTaxAmount      Decimal  @db.Decimal(12, 2)
  lineTotalAmount    Decimal  @db.Decimal(12, 2)

  productName String
  variantName String?
  sku         String?
  productSlug String?
  variantSlug String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  fulfillmentItems FulfillmentItem[]
  returnItems      ReturnItem[]

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
  @@map("order_lines")
}

model OrderAddress {
  id      String           @id @default(cuid())
  orderId String
  type    OrderAddressType

  firstName String?
  lastName  String?
  company   String?

  line1       String
  line2       String?
  postalCode  String
  city        String
  region      String?
  countryCode String

  phone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, type])
  @@index([orderId])
  @@map("order_addresses")
}

model OrderShippingSelection {
  id               String  @id @default(cuid())
  orderId          String  @unique
  shippingMethodId String?

  methodCode   String
  methodName   String
  amount       Decimal      @db.Decimal(12, 2)
  currencyCode CurrencyCode

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  shippingMethod ShippingMethod? @relation(fields: [shippingMethodId], references: [id], onDelete: SetNull)

  @@index([shippingMethodId])
  @@map("order_shipping_selections")
}

model OrderStatusHistory {
  id         String      @id @default(cuid())
  orderId    String
  status     OrderStatus
  reasonCode String?
  notes      String?

  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([status, createdAt])
  @@map("order_status_history")
}
