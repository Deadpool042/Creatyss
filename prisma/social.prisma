// -----------------------------------------------------------------------------
// Domaine: social
// Responsabilité: comptes sociaux connectés, posts sociaux, publication.
// Note sécurité : jamais de token brut en clair — accessTokenHash est un hash,
// et toute clé sensible doit passer par un vault externe.
// -----------------------------------------------------------------------------
// prisma/social.prisma

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  TWITTER_X
  LINKEDIN
  TIKTOK
  PINTEREST
}

enum SocialAccountStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ARCHIVED
}

enum SocialPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
  CANCELLED
}

model SocialAccount {
  id      String @id @default(cuid())
  storeId String

  platform          SocialPlatform
  externalAccountId String
  displayName       String?

  // Jamais de token brut — référence vers un vault externe
  credentialRef String?

  status SocialAccountStatus @default(ACTIVE)

  tokenExpiresAt DateTime?
  connectedAt    DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  posts SocialPost[]

  @@unique([storeId, platform, externalAccountId])
  @@index([storeId])
  @@index([platform])
  @@index([status])
  @@map("social_accounts")
}

model SocialPost {
  id              String @id @default(cuid())
  socialAccountId String
  storeId         String

  content   String
  mediaUrls String[]

  status SocialPostStatus @default(DRAFT)

  scheduledAt DateTime?
  publishedAt DateTime?
  failedAt    DateTime?
  cancelledAt DateTime?

  externalPostId String?
  failureReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([socialAccountId])
  @@index([storeId])
  @@index([status])
  @@index([scheduledAt])
  @@map("social_posts")
}
