// -----------------------------------------------------------------------------
// Domaine: catalog-modeling
// Responsabilité: types produit, attributs, axes de variation, compatibilités.
// -----------------------------------------------------------------------------
// prisma/catalog-modeling.prisma

enum ProductTypeStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum CatalogAttributeValueType {
  TEXT
  BOOLEAN
  INTEGER
  DECIMAL
  COLOR
}

enum CatalogAttributeStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum ProductTypeAttributeKind {
  BASE
  VARIANT_AXIS
}

model ProductType {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  status ProductTypeStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store      Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  attributes ProductTypeAttribute[]
  products   Product[]
  taxRules   TaxRule[]

  @@unique([storeId, code])
  @@index([storeId])
  @@index([status])
  @@map("product_types")
}

model CatalogAttribute {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  valueType CatalogAttributeValueType
  status    CatalogAttributeStatus    @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store            Store                          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productTypeLinks ProductTypeAttribute[]
  productValues    ProductAttributeValue[]
  variantValues    ProductVariantAttributeValue[]

  @@unique([storeId, code])
  @@index([storeId])
  @@index([status])
  @@index([valueType])
  @@map("catalog_attributes")
}

model ProductTypeAttribute {
  id            String @id @default(cuid())
  productTypeId String
  attributeId   String

  kind               ProductTypeAttributeKind
  sortOrder          Int                      @default(0)
  isRequired         Boolean                  @default(false)
  isFilterable       Boolean                  @default(false)
  isVisibleOnProduct Boolean                  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productType ProductType      @relation(fields: [productTypeId], references: [id], onDelete: Cascade)
  attribute   CatalogAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productTypeId, attributeId])
  @@index([productTypeId])
  @@index([attributeId])
  @@index([kind])
  @@map("product_type_attributes")
}
