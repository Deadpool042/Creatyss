// -----------------------------------------------------------------------------
// Domaine: ai
// Responsabilité: génération de contenu admin (fiches produit, blog, SEO, email,
// social) + assistant IA public storefront. Optionnable par capability boutique.
//
// Sécurité : AiCredential.secretRef est un pointeur vault — jamais le secret en clair.
//
// Profondeur de réponse (AiResponseDepth) :
//   QUICK    → budget ~500 tokens  — réponses courtes, autocomplétion rapide
//   STANDARD → budget ~1500 tokens — réponses équilibrées, usage courant
//   DEEP     → budget ~4000 tokens — réponses longues, rédaction complète
//
// Capabilities activantes :
//   AI_CONTENT_GENERATION — génération admin (produits, blog, SEO, email)
//   AI_PUBLIC_ASSISTANT   — assistant storefront public
//   AI_SEO_GENERATION     — génération SEO automatisée
//   AI_SOCIAL_GENERATION  — génération posts sociaux
// -----------------------------------------------------------------------------
// prisma/ai.prisma

enum AiProviderKind {
  ANTHROPIC
  OPENAI
  MISTRAL
  CUSTOM
}

enum AiProviderStatus {
  ACTIVE
  DISABLED
  ARCHIVED
}

enum AiResponseDepth {
  QUICK
  STANDARD
  DEEP
}

enum AiContentKind {
  PRODUCT_DESCRIPTION
  PRODUCT_SHORT_DESCRIPTION
  BLOG_POST_CONTENT
  BLOG_POST_EXCERPT
  SEO_META_TITLE
  SEO_META_DESCRIPTION
  PAGE_CONTENT
  EMAIL_SUBJECT
  EMAIL_BODY
  SOCIAL_POST_CONTENT
  CATEGORY_DESCRIPTION
  CUSTOM
}

enum AiContentGenerationStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
  REJECTED
}

enum AiConversationStatus {
  ACTIVE
  ENDED
  EXPIRED
}

enum AiMessageRole {
  SYSTEM
  USER
  ASSISTANT
}

// ---------------------------------------------------------------------------
// AiProvider — configuration provider IA par boutique (ou global)
// ---------------------------------------------------------------------------
model AiProvider {
  id      String  @id @default(cuid())
  storeId String?

  kind    AiProviderKind
  name    String
  modelId String

  status    AiProviderStatus @default(ACTIVE)
  isDefault Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store              Store?                @relation(fields: [storeId], references: [id], onDelete: SetNull)
  credentials        AiCredential[]
  contentGenerations AiContentGeneration[]
  conversations      AiConversation[]

  @@index([storeId])
  @@index([kind])
  @@index([status])
  @@map("ai_providers")
}

// ---------------------------------------------------------------------------
// AiCredential — référence clé API (pointeur vault, jamais le secret brut)
// ---------------------------------------------------------------------------
model AiCredential {
  id         String @id @default(cuid())
  providerId String

  // Référence vers le secret dans un vault externe (ex. Vault, AWS SM, etc.)
  // Ne jamais stocker la clé API ici.
  secretRef String

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  provider AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId])
  @@map("ai_credentials")
}

// ---------------------------------------------------------------------------
// AiDepthPolicy — budget token par boutique × usage
// ---------------------------------------------------------------------------
model AiDepthPolicy {
  id      String  @id @default(cuid())
  storeId String?

  // Usage : "content_generation" | "public_assistant" | "seo" | "social"
  usageKind String

  depth AiResponseDepth @default(STANDARD)

  // Limites optionnelles en override (null = utiliser les défauts du depth)
  maxTokens Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@unique([storeId, usageKind])
  @@index([storeId])
  @@map("ai_depth_policies")
}

// ---------------------------------------------------------------------------
// AiContentGeneration — log de génération de contenu (admin)
// ---------------------------------------------------------------------------
model AiContentGeneration {
  id            String  @id @default(cuid())
  storeId       String
  providerId    String
  requestedById String?

  contentKind AiContentKind
  depth       AiResponseDepth           @default(STANDARD)
  status      AiContentGenerationStatus @default(PENDING)

  // Contexte d'entrée (prompt métier)
  inputContext Json?

  // Résultat généré
  outputText String?

  // Métriques tokens pour quotas / billing
  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  totalTokens      Int @default(0)

  startedAt     DateTime?
  completedAt   DateTime?
  failedAt      DateTime?
  failureReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store       Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider    AiProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)
  requestedBy User?      @relation(fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([providerId])
  @@index([requestedById])
  @@index([contentKind])
  @@index([status])
  @@index([createdAt])
  @@map("ai_content_generations")
}

// ---------------------------------------------------------------------------
// AiConversation — session assistant IA public storefront
// ---------------------------------------------------------------------------
model AiConversation {
  id         String  @id @default(cuid())
  storeId    String
  providerId String
  customerId String?

  status AiConversationStatus @default(ACTIVE)
  depth  AiResponseDepth      @default(STANDARD)

  // Contexte système injecté pour la session (instructions boutique)
  systemPrompt String?

  totalTokens Int @default(0)

  startedAt DateTime  @default(now())
  endedAt   DateTime?
  expiredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store                   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  provider AiProvider              @relation(fields: [providerId], references: [id], onDelete: Restrict)
  customer Customer?               @relation(fields: [customerId], references: [id], onDelete: SetNull)
  messages AiConversationMessage[]

  @@index([storeId])
  @@index([providerId])
  @@index([customerId])
  @@index([status])
  @@index([startedAt])
  @@map("ai_conversations")
}

// ---------------------------------------------------------------------------
// AiConversationMessage — messages d'une conversation IA
// ---------------------------------------------------------------------------
model AiConversationMessage {
  id             String @id @default(cuid())
  conversationId String

  role    AiMessageRole
  content String

  promptTokens     Int @default(0)
  completionTokens Int @default(0)

  createdAt DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([role])
  @@map("ai_conversation_messages")
}

// ---------------------------------------------------------------------------
// AiUsageSummary — agrégat tokens/requêtes par boutique × période
// (utilisé pour quotas, billing, dashboards)
// ---------------------------------------------------------------------------
model AiUsageSummary {
  id      String @id @default(cuid())
  storeId String

  periodStart DateTime
  periodEnd   DateTime

  usageKind String

  requestCount     Int @default(0)
  promptTokens     Int @default(0)
  completionTokens Int @default(0)
  totalTokens      Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, usageKind, periodStart, periodEnd])
  @@index([storeId])
  @@index([usageKind])
  @@index([periodStart])
  @@map("ai_usage_summaries")
}
