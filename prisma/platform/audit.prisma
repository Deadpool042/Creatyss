enum AuditActorType {
  USER
  API_CLIENT
  SYSTEM
}

enum AuditLevel {
  INFO
  WARNING
  CRITICAL
}

model AuditLog {
  id      String  @id @default(cuid())
  storeId String?

  actorType        AuditActorType
  actorUserId      String?
  actorApiClientId String?

  actionCode String
  entityType String
  entityId   String?

  level      AuditLevel @default(INFO)
  message    String?
  reasonCode String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  store          Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  actorUser      User?      @relation("AuditLogActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorApiClient ApiClient? @relation("AuditLogActorApiClient", fields: [actorApiClientId], references: [id], onDelete: SetNull)

  changes AuditLogChange[]

  @@index([storeId, createdAt])
  @@index([actorType, createdAt])
  @@index([actorUserId, createdAt])
  @@index([actorApiClientId, createdAt])
  @@index([entityType, entityId, createdAt])
  @@index([actionCode, createdAt])
  @@index([level, createdAt])
  @@map("audit_logs")
}

model AuditLogChange {
  id         String @id @default(cuid())
  auditLogId String

  fieldName String
  oldValue  String?
  newValue  String?

  createdAt DateTime @default(now())

  auditLog AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)

  @@index([auditLogId])
  @@index([fieldName])
  @@map("audit_log_changes")
}
