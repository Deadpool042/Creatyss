// -----------------------------------------------------------------------------
// Domaine: audit
// Responsabilité: traçabilité sensible et gouvernée.
// -----------------------------------------------------------------------------
// prisma/audit.prisma

enum AuditSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AuditActorKind {
  USER
  API_CLIENT
  SYSTEM
}

model AuditLog {
  id      String  @id @default(cuid())
  storeId String?

  actorKind   AuditActorKind
  userId      String?
  apiClientId String?

  action     String
  entityType String
  entityId   String?
  summary    String?

  severity AuditSeverity @default(INFO)

  ipAddress String?
  userAgent String?

  occurredAt DateTime @default(now())
  createdAt  DateTime @default(now())

  store     Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  user      User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiClient ApiClient?       @relation(fields: [apiClientId], references: [id], onDelete: SetNull)
  changes   AuditLogChange[]

  @@index([storeId])
  @@index([userId])
  @@index([apiClientId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([severity])
  @@index([occurredAt])
  @@map("audit_logs")
}

model AuditLogChange {
  id         String @id @default(cuid())
  auditLogId String

  fieldName String
  oldValue  String?
  newValue  String?

  createdAt DateTime @default(now())

  auditLog AuditLog @relation(fields: [auditLogId], references: [id], onDelete: Cascade)

  @@index([auditLogId])
  @@index([fieldName])
  @@map("audit_log_changes")
}
