enum ObservabilitySignalLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ObservabilitySignalStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
  ARCHIVED
}

model ObservabilitySignal {
  id      String  @id @default(cuid())
  storeId String?

  code        String?
  title       String
  description String?

  subjectType String?
  subjectId   String?

  level  ObservabilitySignalLevel  @default(INFO)
  status ObservabilitySignalStatus @default(OPEN)

  reasonCode String?
  sourceType String?
  sourceRef  String?

  detectedAt     DateTime?
  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  archivedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  events ObservabilitySignalEvent[]

  @@index([storeId, status])
  @@index([level, status])
  @@index([subjectType, subjectId])
  @@index([detectedAt])
  @@map("observability_signals")
}

model ObservabilitySignalEvent {
  id                    String  @id @default(cuid())
  observabilitySignalId String
  actorUserId           String?

  eventType   String
  message     String?
  payloadJson String?

  createdAt DateTime @default(now())

  observabilitySignal ObservabilitySignal @relation(fields: [observabilitySignalId], references: [id], onDelete: Cascade)
  actorUser           User?               @relation("ObservabilitySignalEventActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([observabilitySignalId, createdAt])
  @@index([actorUserId])
  @@index([eventType, createdAt])
  @@map("observability_signal_events")
}
