// -----------------------------------------------------------------------------
// Domaine: observability
// Responsabilité: explicabilité, corrélation, diagnostics métier/techniques.
// -----------------------------------------------------------------------------
// prisma/observability.prisma

enum ObservabilityLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ObservabilityRecordKind {
  ACCESS_DECISION
  WORKFLOW_STATE
  APPROVAL_DECISION
  INTEGRATION_EVENT
  DOMAIN_DIAGNOSTIC
  OTHER
}

model ObservabilityRecord {
  id      String  @id @default(cuid())
  storeId String?

  kind  ObservabilityRecordKind
  level ObservabilityLevel      @default(INFO)

  code    String
  title   String
  summary String?

  entityType String?
  entityId   String?

  correlationKey String?
  contextData    Json?

  userId      String?
  apiClientId String?

  recordedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  store     Store?     @relation(fields: [storeId], references: [id], onDelete: SetNull)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiClient ApiClient? @relation(fields: [apiClientId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([kind])
  @@index([level])
  @@index([code])
  @@index([entityType, entityId])
  @@index([correlationKey])
  @@index([recordedAt])
  @@map("observability_records")
}
