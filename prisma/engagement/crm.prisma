enum CrmContactStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  ARCHIVED
}

enum CrmTagStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

model CrmContact {
  id         String  @id @default(cuid())
  storeId    String
  customerId String? @unique

  status CrmContactStatus @default(ACTIVE)

  source         String?
  lifecycleStage String?
  notes          String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  tagLinks CrmContactTag[]

  @@unique([storeId, customerId])
  @@index([storeId, status])
  @@index([customerId])
  @@index([lifecycleStage])
  @@map("crm_contacts")
}

model CrmTag {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  status CrmTagStatus @default(ACTIVE)

  colorToken String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  contactLinks CrmContactTag[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@map("crm_tags")
}

model CrmContactTag {
  id           String @id @default(cuid())
  crmContactId String
  crmTagId     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  crmContact CrmContact @relation(fields: [crmContactId], references: [id], onDelete: Cascade)
  crmTag     CrmTag     @relation(fields: [crmTagId], references: [id], onDelete: Cascade)

  @@unique([crmContactId, crmTagId])
  @@index([crmTagId])
  @@map("crm_contact_tags")
}
