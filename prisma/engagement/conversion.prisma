enum ConversionFlowStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ConversionFlowType {
  CART_RECOVERY
  UPSELL
  CROSS_SELL
  THRESHOLD
}

model ConversionFlow {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  type   ConversionFlowType
  status ConversionFlowStatus @default(DRAFT)

  isActive Boolean @default(true)
  priority Int     @default(0)

  thresholdAmount Decimal?      @db.Decimal(12, 2)
  currencyCode    CurrencyCode?

  startsAt DateTime?
  endsAt   DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  productLinks ConversionFlowProduct[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([type, status])
  @@index([isActive, priority])
  @@index([startsAt, endsAt])
  @@map("conversion_flows")
}

model ConversionFlowProduct {
  id               String @id @default(cuid())
  conversionFlowId String
  productId        String

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversionFlow ConversionFlow @relation(fields: [conversionFlowId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([conversionFlowId, productId])
  @@index([conversionFlowId, sortOrder])
  @@index([productId])
  @@map("conversion_flow_products")
}
