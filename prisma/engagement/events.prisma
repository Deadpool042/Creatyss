// -----------------------------------------------------------------------------
// Domaine: events
// Responsabilité: événements publics, inscriptions, publication.
// -----------------------------------------------------------------------------
// prisma/events.prisma

enum EventStatus {
  DRAFT
  ACTIVE
  CANCELLED
  ARCHIVED
}

enum EventRegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLISTED
}

model Event {
  id      String @id @default(cuid())
  storeId String

  slug        String
  title       String
  excerpt     String?
  description String?

  status     EventStatus @default(DRAFT)
  isFeatured Boolean     @default(false)

  startsAt            DateTime
  endsAt              DateTime?
  locationName        String?
  locationLine1       String?
  locationLine2       String?
  locationPostalCode  String?
  locationCity        String?
  locationRegion      String?
  locationCountryCode String?

  capacity     Int?
  coverImageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store          Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  coverImage     MediaAsset?         @relation(fields: [coverImageId], references: [id], onDelete: SetNull)
  registrations  EventRegistration[]
  emails         EmailMessage[]
  supportTickets SupportTicket[]

  @@unique([storeId, slug])
  @@index([storeId])
  @@index([status])
  @@index([isFeatured])
  @@index([startsAt])
  @@map("events")
}

model EventRegistration {
  id         String  @id @default(cuid())
  eventId    String
  customerId String?

  status EventRegistrationStatus @default(PENDING)

  email     String
  firstName String?
  lastName  String?
  phone     String?
  notes     String?

  registeredAt DateTime  @default(now())
  confirmedAt  DateTime?
  cancelledAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event    Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([customerId])
  @@index([status])
  @@index([registeredAt])
  @@map("event_registrations")
}
