// -----------------------------------------------------------------------------
// Domaine: auth
// Responsabilité: identités d'authentification, credentials, sessions,
// recovery, MFA, bootstrap admin.
// -----------------------------------------------------------------------------
// prisma/auth.prisma

enum AuthIdentityStatus {
  PENDING_BOOTSTRAP
  ACTIVE
  LOCKED
  SUSPENDED
  RESET_REQUIRED
  DISABLED
}

enum AuthSessionStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum AuthRecoveryStatus {
  PENDING
  CONSUMED
  EXPIRED
  REVOKED
}

enum AuthMfaMethod {
  TOTP
}

model AuthIdentity {
  id     String @id @default(cuid())
  userId String @unique

  status AuthIdentityStatus @default(PENDING_BOOTSTRAP)

  lastLoginAt       DateTime?
  lastLoginFailedAt DateTime?
  failedLoginCount  Int       @default(0)
  lockedAt          DateTime?
  passwordChangedAt DateTime?
  resetRequiredAt   DateTime?

  mustChangePassword Boolean @default(false)
  mfaEnabled         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordCredential AuthPasswordCredential?
  sessions           AuthSession[]
  recoveryRequests   AuthRecoveryRequest[]
  mfaEnrollments     AuthMfaEnrollment[]
  recoveryCodes      AuthRecoveryCode[]

  @@index([status])
  @@index([mfaEnabled])
  @@map("auth_identities")
}

model AuthPasswordCredential {
  id         String @id @default(cuid())
  identityId String @unique

  passwordHash    String
  passwordVersion Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identity AuthIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@map("auth_password_credentials")
}

model AuthSession {
  id         String @id @default(cuid())
  identityId String

  sessionTokenHash String            @unique
  status           AuthSessionStatus @default(ACTIVE)

  ipAddress   String?
  userAgent   String?
  deviceLabel String?

  lastSeenAt DateTime?
  expiresAt  DateTime
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identity AuthIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([identityId])
  @@index([status])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model AuthRecoveryRequest {
  id                String  @id @default(cuid())
  identityId        String
  requestedByUserId String?

  tokenHash String             @unique
  status    AuthRecoveryStatus @default(PENDING)

  expiresAt  DateTime
  consumedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identity        AuthIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)
  requestedByUser User?        @relation(fields: [requestedByUserId], references: [id], onDelete: SetNull)

  @@index([identityId])
  @@index([requestedByUserId])
  @@index([status])
  @@index([expiresAt])
  @@map("auth_recovery_requests")
}

model AuthMfaEnrollment {
  id         String @id @default(cuid())
  identityId String

  method     AuthMfaMethod @default(TOTP)
  label      String?
  secretHash String
  isPrimary  Boolean       @default(true)
  verifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identity AuthIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([identityId])
  @@index([method])
  @@map("auth_mfa_enrollments")
}

model AuthRecoveryCode {
  id         String @id @default(cuid())
  identityId String

  codeHash String    @unique
  usedAt   DateTime?

  createdAt DateTime @default(now())

  identity AuthIdentity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  @@index([identityId])
  @@map("auth_recovery_codes")
}
