enum ChannelStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ChannelType {
  GOOGLE_SHOPPING
  META_CATALOG
  MARKETPLACE
  INTERNAL_FEED
  OTHER
}

enum ChannelPublicationStatus {
  PENDING
  ELIGIBLE
  INELIGIBLE
  PUBLISHED
  REJECTED
  EXCLUDED
  SUSPENDED
  ARCHIVED
}

model Channel {
  id      String @id @default(cuid())
  storeId String

  code        String
  name        String
  description String?

  type   ChannelType
  status ChannelStatus @default(DRAFT)

  isEnabled Boolean @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  productStatuses ChannelProductStatus[]
  variantStatuses ChannelVariantStatus[]

  @@unique([storeId, code])
  @@index([storeId, status])
  @@index([type, status])
  @@index([isEnabled])
  @@map("channels")
}

model ChannelProductStatus {
  id        String @id @default(cuid())
  channelId String
  productId String

  publicationStatus ChannelPublicationStatus @default(PENDING)
  isEligible        Boolean                  @default(false)

  reasonCode String?
  notes      String?

  publishedAt DateTime?
  rejectedAt  DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([channelId, productId])
  @@index([productId, publicationStatus])
  @@index([channelId, publicationStatus])
  @@map("channel_product_statuses")
}

model ChannelVariantStatus {
  id        String @id @default(cuid())
  channelId String
  variantId String

  publicationStatus ChannelPublicationStatus @default(PENDING)
  isEligible        Boolean                  @default(false)

  reasonCode String?
  notes      String?

  publishedAt DateTime?
  rejectedAt  DateTime?
  archivedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([channelId, variantId])
  @@index([variantId, publicationStatus])
  @@index([channelId, publicationStatus])
  @@map("channel_variant_statuses")
}
