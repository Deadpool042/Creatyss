# Baseline sample environment for the local Docker foundation.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_PORT=3000
DATABASE_URL=postgresql://creatyss:creatyss@db:5432/creatyss
ADMIN_SESSION_SECRET=change-me-with-a-long-random-secret
CART_SESSION_SECRET=change-me-with-a-second-long-random-secret
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Local native default: Mailpit via pnpm dev
EMAIL_PROVIDER=mailpit
EMAIL_FROM_ADDRESS=no-reply@creatyss.local
EMAIL_FROM_NAME=Creatyss
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025

# If app runs in Docker and Mailpit runs on host machine, set MAILPIT_SMTP_HOST=host.docker.internal
# Production: set EMAIL_PROVIDER=brevo with real Brevo values below.
# Placeholders below are intentionally invalid when EMAIL_PROVIDER=brevo.
BREVO_API_KEY=placeholder-change-me
BREVO_FROM_ADDRESS=no-reply@example.com
BREVO_FROM_NAME=Creatyss
WC_BASE_URL=https://creatyss.com
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=

POSTGRES_DB=creatyss
POSTGRES_USER=creatyss
POSTGRES_PASSWORD=creatyss
POSTGRES_PORT=5433

UPLOADS_DIR=public/uploads
